{
  "name": "paper-hoard",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted family physical book library with the Smaug Discord bot",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run copy-assets",
    "copy-assets": "node -e \"const fs=require('fs');const path=require('path');function cp(s,d){fs.mkdirSync(d,{recursive:true});for(const e of fs.readdirSync(s,{withFileTypes:true})){const sp=path.join(s,e.name),dp=path.join(d,e.name);e.isDirectory()?cp(sp,dp):fs.copyFileSync(sp,dp);}}cp('src/web/views','dist/web/views');cp('src/web/public','dist/web/public');fs.copyFileSync('node_modules/@zxing/browser/umd/zxing-browser.min.js','dist/web/public/zxing-browser.min.js');\"",
    "start:bot": "node dist/bot/index.js",
    "start:web": "node dist/web/index.js",
    "dev:bot": "tsx watch src/bot/index.ts",
    "dev:web": "tsx watch src/web/index.ts",
    "register-commands": "tsx src/bot/register-commands.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^8.0.3",
    "@fastify/view": "^11.0.0",
    "@prisma/client": "^6.1.0",
    "@zxing/browser": "^0.2.0",
    "@zxing/library": "^0.22.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "fastify": "^5.2.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "undici": "^7.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^22.10.5",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
