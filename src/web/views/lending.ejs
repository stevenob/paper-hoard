<% const pageTitle = 'Currently lent out' %>
<%- include('_header') %>

<%
  function days(d) { return Math.floor((Date.now() - new Date(d).getTime()) / 86400000); }
  function isOverdue(due) { return due && new Date(due).getTime() < Date.now(); }
  function dueInDays(due) { return Math.ceil((new Date(due).getTime() - Date.now()) / 86400000); }
%>

<%- include('_page_hero', {
  icon: '📤',
  title: 'Currently lent out',
  blurb: copies.length === 0 ? 'Nothing is checked out right now.' : 'Track which copies are out with friends. Mark returned when they come back.',
  stats: copies.length > 0 ? [
    { value: copies.length, label: 'out' },
    overdueCount > 0 ? { value: overdueCount, label: 'overdue' } : null,
    avgOutDays > 0 ? { value: avgOutDays + ' d', label: 'avg out' } : null
  ] : null,
  tint: 'green'
}) %>

<% if (copies.length === 0) { %>
  <p class="hint">Nothing is checked out right now. Mark a copy as lent from its detail page.</p>
<% } else { %>
  <table class="lending-table">
    <thead>
      <tr><th>Book</th><th>Lent to</th><th>Out for</th><th>Due back</th><th></th></tr>
    </thead>
    <tbody>
      <% copies.forEach(function(c) {
        const overdue = isOverdue(c.dueBack);
        const dueDays = c.dueBack ? dueInDays(c.dueBack) : null;
        const cover = c.coverPath ? '/uploads/' + c.coverPath : c.book.thumbnailUrl;
      %>
        <tr<%= overdue ? ' class="overdue"' : '' %>>
          <td data-label="Book">
            <a href="/library/copy/<%= c.id %>" style="color:inherit;text-decoration:none">
              <div class="lending-book">
                <% if (cover) { %>
                  <img class="cover" src="<%= cover %>" alt="" loading="lazy" />
                <% } else { %>
                  <span class="cover" aria-hidden="true"></span>
                <% } %>
                <div class="info">
                  <em><%= c.book.title %></em>
                  <div class="author"><%= c.book.authors.join(', ') %></div>
                </div>
              </div>
            </a>
          </td>
          <td data-label="Lent to"><div class="lending-borrower"><%= c.lentTo %></div></td>
          <td data-label="Out for"><span class="lending-time"><%= days(c.lentAt) %> day<%= days(c.lentAt) === 1 ? '' : 's' %></span></td>
          <td data-label="Due back">
            <% if (c.dueBack) { %>
              <div class="lending-time"><%= new Date(c.dueBack).toISOString().slice(0, 10) %></div>
              <% if (overdue) { %>
                <span class="lending-pill overdue">overdue <%= -dueDays %>d</span>
              <% } else if (dueDays !== null && dueDays <= 14) { %>
                <span class="lending-pill due-soon">due in <%= dueDays %>d</span>
              <% } %>
            <% } else { %>
              <span class="lending-time" style="font-style:italic">no date set</span>
            <% } %>
          </td>
          <td>
            <% if (activeUser) { %>
              <form method="post" action="/library/copy/<%= c.id %>/return" style="display:inline">
                <button type="submit" class="lending-action-btn">✓ Mark returned</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('_footer') %>
