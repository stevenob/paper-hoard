<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' · ' + appName : appName %></title>
    <link rel="stylesheet" href="/static/style.css" />
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href="/">📚 Paper Hoard</a>
      <nav>
        <a href="/scan">Scan</a>
        <a href="/library">Library</a>
        <a href="/trophies">Trophies</a>
        <a href="/completions">Completions</a>
        <a href="/users">Users</a>
      </nav>
      <div class="active-user">
        <% if (activeUser) { %>
          <span>👤 <strong><%= activeUser.displayName %></strong></span>
          <form method="post" action="/auth/logout" style="display:inline">
            <button type="submit" class="link">logout</button>
          </form>
        <% } else if (oauthConfigured) { %>
          <a href="/auth/login" class="login-link">Login with Discord</a>
        <% } else { %>
          <span class="hint">login disabled</span>
        <% } %>
      </div>
    </header>
    <main>
