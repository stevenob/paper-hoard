<% const pageTitle = 'Series' %>
<%- include('_header') %>

<h1>Series</h1>

<% if (series.length === 0) { %>
  <p>No series detected yet. Set one on a book's <em>Edit metadata</em> page, or scan books that include series info.</p>
<% } else { %>
  <ul>
    <% series.forEach(function(s) { %>
      <li><a href="/series/<%= encodeURIComponent(s.name) %>"><strong><%= s.name %></strong></a> <span class="hint"><%= s.count %> book<%= s.count === 1 ? '' : 's' %></span></li>
    <% }) %>
  </ul>
<% } %>

<%- include('_footer') %>
