<% const pageTitle = 'Library' %>
<%- include('_header') %>

<div class="library-header">
  <h1>Physical Library</h1>
  <% function withParam(name, value) {
    const u = new URLSearchParams();
    if (params.q) u.set('q', params.q);
    if (params.shelf) u.set('shelf', params.shelf);
    if (params.shelf) u.set('shelf', params.shelf);
    u.set('sort', params.sort);
    u.set('order', params.order);
    u.set('view', name === 'view' ? value : params.view);
    u.set('page', String(params.page));
    return '/library?' + u.toString();
  } %>
  <div class="view-toggle" role="tablist" aria-label="View mode">
    <a href="<%= withParam('view', 'grid') %>" class="view-toggle-btn <%= params.view === 'grid' ? 'active' : '' %>" role="tab" aria-selected="<%= params.view === 'grid' %>">▦ Grid</a>
    <a href="<%= withParam('view', 'list') %>" class="view-toggle-btn <%= params.view === 'list' ? 'active' : '' %>" role="tab" aria-selected="<%= params.view === 'list' %>">≡ List</a>
  </div>
</div>
<form method="get" action="/library" class="library-filters">
  <label><span class="hint">Search</span>
    <input type="search" name="q" value="<%= params.q || '' %>" placeholder="Title or author" />
  </label>
  <label><span class="hint">Sort</span>
    <select name="sort">
      <% sortFields.forEach(function(s) { %>
        <option value="<%= s %>" <%= params.sort === s ? 'selected' : '' %>><%= s %></option>
      <% }) %>
    </select>
  </label>
  <label><span class="hint">Order</span>
    <select name="order">
      <option value="asc" <%= params.order === 'asc' ? 'selected' : '' %>>asc</option>
      <option value="desc" <%= params.order === 'desc' ? 'selected' : '' %>>desc</option>
    </select>
  </label>
  <input type="hidden" name="view" value="<%= params.view %>" />
  <button type="submit">Apply</button>
  <% if (params.q || params.sort !== 'author' || params.order !== 'asc') { %>
    <a href="/library?view=<%= params.view %>" class="hint">reset</a>
  <% } %>
</form>

<% if (activeShelf) { %>
  <p class="hint">Filtered by shelf <a href="/library?view=<%= params.view %>" class="pill pill-tag" title="Clear"><%= activeShelf.name %> ×</a></p>
<% } %>

<p class="hint">Showing <%= copies.length %> of <%= total %> total<% if (totalPages > 1) { %> · page <%= params.page %> of <%= totalPages %><% } %></p>

<% if (copies.length === 0) { %>
  <% if (params.q || params.shelf) { %>
    <p>No matches. <a href="/library?view=<%= params.view %>">Show all</a>.</p>
  <% } else { %>
    <p>No physical copies yet. Use <a href="/scan">/scan</a> in the web UI or <code>/scan</code> in Discord to add one.</p>
  <% } %>
<% } else if (params.view === 'grid') { %>
  <ul class="poster-grid">
    <% copies.forEach(function(c) {
      const cover = c.coverPath ? '/uploads/' + c.coverPath : c.book.thumbnailUrl;
    %>
      <li class="poster">
        <a href="/library/copy/<%= c.id %>" class="poster-link" aria-label="<%= c.book.title %>">
          <% if (cover) { %>
            <img src="<%= cover %>" alt="" loading="lazy" />
          <% } else { %>
            <div class="poster-fallback"><span><%= c.book.title %></span></div>
          <% } %>
          <div class="poster-meta">
            <strong class="poster-title"><%= c.book.title %></strong>
            <span class="poster-author"><%= c.book.authors.join(', ') %></span>
          </div>
        </a>
      </li>
    <% }) %>
  </ul>
<% } else { %>
  <% if (activeUser) { %>
    <p class="hint">Tip: tick rows to bulk-edit. <a href="/library/dupes">Find duplicate books →</a></p>
  <% } %>
  <form method="post" action="/library/bulk-edit" id="bulk-form">
  <table class="data library-list">
    <thead>
      <tr>
        <% if (activeUser) { %><th><input type="checkbox" id="bulk-select-all" aria-label="Select all"></th><% } %>
        <th>Title</th><th>Authors</th><th>Condition</th><th>Edition</th><th>Shelves</th><th>Added</th>
      </tr>
    </thead>
    <tbody>
      <% copies.forEach(function(c) { %>
        <tr>
          <% if (activeUser) { %>
            <td><input type="checkbox" name="copyIds" value="<%= c.id %>" class="bulk-row-checkbox" aria-label="Select copy"></td>
          <% } %>
          <td data-label="Title"><a href="/library/copy/<%= c.id %>"><%= c.book.title %></a><% if (c.book.kindleAsin) { %> <span class="pill pill-tag" title="Kindle ASIN on file" style="font-size:.75em">📖</span><% } %></td>
          <td data-label="Authors"><% if (c.book.authors && c.book.authors.length > 0) { %><% c.book.authors.forEach(function(a, i) { %><% if (i > 0) { %>, <% } %><% const aslug = authorSlug(a); %><% if (aslug) { %><a href="/authors/<%= aslug %>"><%= a %></a><% } else { %><%= a %><% } %><% }) %><% } %></td>
          <td data-label="Condition"><%= c.condition || '—' %></td>
          <td data-label="Edition"><%= c.edition || '—' %></td>
          <td data-label="Shelves"><% (c.shelves || []).forEach(function(sc){ %><a href="/shelves/<%= sc.shelf.slug %>" class="pill pill-tag"><%= sc.shelf.name %></a> <% }) %></td>
          <td data-label="Added"><%= c.addedAt.toISOString().slice(0,10) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <% if (activeUser) { %>
    <div id="bulk-bar" class="bulk-bar" hidden>
      <span><strong id="bulk-count">0</strong> selected</span>
      <select name="action" id="bulk-action">
        <option value="add-shelf">Add to shelf</option>
        <option value="remove-shelf">Remove from shelf</option>
        <option value="set-edition">Set edition</option>
        <option value="set-condition">Set condition</option>
        <option value="set-series">Set series (auto-number)</option>
        <option value="trash">Move to trash</option>
      </select>
      <input type="text" name="value" id="bulk-value" list="bulk-value-options" placeholder="value" />
      <datalist id="bulk-value-options"></datalist>
      <button type="submit" class="primary">Apply</button>
    </div>
  <% } %>
  </form>
  <script>
    (function() {
      const form = document.getElementById('bulk-form');
      if (!form) return;
      const bar = document.getElementById('bulk-bar');
      if (!bar) return;
      const countEl = document.getElementById('bulk-count');
      const action = document.getElementById('bulk-action');
      const value = document.getElementById('bulk-value');
      const dl = document.getElementById('bulk-value-options');
      const all = document.getElementById('bulk-select-all');
      const rows = form.querySelectorAll('.bulk-row-checkbox');

      const editions = <%- JSON.stringify(['hardcover','paperback','mass-market','special','signed','boxset','other']) %>;
      const conditions = <%- JSON.stringify(['new','like-new','good','fair','poor']) %>;

      function refresh() {
        const checked = form.querySelectorAll('.bulk-row-checkbox:checked');
        const n = checked.length;
        countEl.textContent = String(n);
        bar.hidden = n === 0;
      }
      function syncDatalist() {
        dl.innerHTML = '';
        let opts = [];
        if (action.value === 'set-edition') opts = editions;
        else if (action.value === 'set-condition') opts = conditions;
        else opts = []; // shelf names + series names: free text
        opts.forEach(function(o) {
          const opt = document.createElement('option');
          opt.value = o;
          dl.appendChild(opt);
        });
        // Tweak the placeholder per action so the value field is self-explanatory.
        if (action.value === 'set-series') {
          value.placeholder = 'series name (e.g. Mistborn) — books numbered by selection order';
        } else if (action.value === 'add-shelf' || action.value === 'remove-shelf') {
          value.placeholder = 'shelf name';
        } else if (action.value === 'set-edition') {
          value.placeholder = 'edition';
        } else if (action.value === 'set-condition') {
          value.placeholder = 'condition';
        } else {
          value.placeholder = 'value';
        }
        // Hide the value input for trash since no value is needed.
        value.style.display = action.value === 'trash' ? 'none' : '';
        value.required = action.value === 'add-shelf' || action.value === 'remove-shelf' || action.value === 'set-series';
      }
      rows.forEach(function(r) { r.addEventListener('change', refresh); });
      if (all) {
        all.addEventListener('change', function() {
          rows.forEach(function(r) { r.checked = all.checked; });
          refresh();
        });
      }
      action.addEventListener('change', syncDatalist);
      syncDatalist();
      refresh();
      form.addEventListener('submit', function(e) {
        if (action.value === 'trash' && !confirm('Move ' + countEl.textContent + ' copies to trash?')) {
          e.preventDefault();
        }
      });
    })();
  </script>
<% } %>

<% if (totalPages > 1) { %>
  <% function pageUrl(n) {
    const u = new URLSearchParams();
    if (params.q) u.set('q', params.q);
    if (params.shelf) u.set('shelf', params.shelf);
    u.set('sort', params.sort);
    u.set('order', params.order);
    u.set('view', params.view);
    u.set('page', String(n));
    return '/library?' + u.toString();
  } %>
  <nav class="pager">
    <% if (params.page > 1) { %><a href="<%= pageUrl(params.page - 1) %>">← prev</a><% } %>
    <span class="hint">page <%= params.page %> / <%= totalPages %></span>
    <% if (params.page < totalPages) { %><a href="<%= pageUrl(params.page + 1) %>">next →</a><% } %>
  </nav>
<% } %>

<%- include('_footer') %>
