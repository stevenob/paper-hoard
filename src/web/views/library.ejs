<% const pageTitle = 'Library' %>
<%- include('_header') %>

<div class="library-header">
  <h1>Physical Library</h1>
  <% function withParam(name, value) {
    const u = new URLSearchParams();
    if (params.q) u.set('q', params.q);
    if (params.shelf) u.set('shelf', params.shelf);
    if (params.shelf) u.set('shelf', params.shelf);
    u.set('sort', params.sort);
    u.set('order', params.order);
    u.set('view', name === 'view' ? value : params.view);
    u.set('page', String(params.page));
    return '/library?' + u.toString();
  } %>
  <div class="view-toggle" role="tablist" aria-label="View mode">
    <a href="<%= withParam('view', 'grid') %>" class="view-toggle-btn <%= params.view === 'grid' ? 'active' : '' %>" role="tab" aria-selected="<%= params.view === 'grid' %>">▦ Grid</a>
    <a href="<%= withParam('view', 'list') %>" class="view-toggle-btn <%= params.view === 'list' ? 'active' : '' %>" role="tab" aria-selected="<%= params.view === 'list' %>">≡ List</a>
  </div>
</div>

<form method="get" action="/library" class="library-filters">
  <label><span class="hint">Search</span>
    <input type="search" name="q" value="<%= params.q || '' %>" placeholder="Title or author" />
  </label>
  <label><span class="hint">Sort</span>
    <select name="sort">
      <% sortFields.forEach(function(s) { %>
        <option value="<%= s %>" <%= params.sort === s ? 'selected' : '' %>><%= s %></option>
      <% }) %>
    </select>
  </label>
  <label><span class="hint">Order</span>
    <select name="order">
      <option value="desc" <%= params.order === 'desc' ? 'selected' : '' %>>desc</option>
      <option value="asc" <%= params.order === 'asc' ? 'selected' : '' %>>asc</option>
    </select>
  </label>
  <input type="hidden" name="view" value="<%= params.view %>" />
  <button type="submit">Apply</button>
  <% if (params.q || params.sort !== 'added' || params.order !== 'desc') { %>
    <a href="/library?view=<%= params.view %>" class="hint">reset</a>
  <% } %>
</form>

<% if (activeShelf) { %>
  <p class="hint">Filtered by shelf <a href="/library?view=<%= params.view %>" class="pill pill-tag" title="Clear"><%= activeShelf.name %> ×</a></p>
<% } %>

<p class="hint">Showing <%= copies.length %> of <%= total %> total<% if (totalPages > 1) { %> · page <%= params.page %> of <%= totalPages %><% } %></p>

<% if (copies.length === 0) { %>
  <% if (params.q || params.shelf) { %>
    <p>No matches. <a href="/library?view=<%= params.view %>">Show all</a>.</p>
  <% } else { %>
    <p>No physical copies yet. Use <a href="/scan">/scan</a> in the web UI or <code>/scan</code> in Discord to add one.</p>
  <% } %>
<% } else if (params.view === 'grid') { %>
  <ul class="poster-grid">
    <% copies.forEach(function(c) {
      const cover = c.coverPath ? '/uploads/' + c.coverPath : c.book.thumbnailUrl;
    %>
      <li class="poster">
        <a href="/library/copy/<%= c.id %>" class="poster-link" aria-label="<%= c.book.title %>">
          <% if (cover) { %>
            <img src="<%= cover %>" alt="" loading="lazy" />
          <% } else { %>
            <div class="poster-fallback"><span><%= c.book.title %></span></div>
          <% } %>
          <div class="poster-meta">
            <strong class="poster-title"><%= c.book.title %></strong>
            <span class="poster-author"><%= c.book.authors.join(', ') %></span>
          </div>
        </a>
      </li>
    <% }) %>
  </ul>
<% } else { %>
  <table class="data">
    <thead>
      <tr><th>Title</th><th>Authors</th><th>Condition</th><th>Edition</th><th>Location</th><th>Added</th></tr>
    </thead>
    <tbody>
      <% copies.forEach(function(c) { %>
        <tr>
          <td data-label="Title"><a href="/library/copy/<%= c.id %>"><%= c.book.title %></a></td>
          <td data-label="Authors"><%= c.book.authors.join(', ') %></td>
          <td data-label="Condition"><%= c.condition || '—' %></td>
          <td data-label="Edition"><%= c.edition || '—' %></td>
          <td data-label="Shelves"><% (c.shelves || []).forEach(function(sc){ %><a href="/shelves/<%= sc.shelf.slug %>" class="pill pill-tag"><%= sc.shelf.name %></a> <% }) %></td>
          <td data-label="Added"><%= c.addedAt.toISOString().slice(0,10) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<% if (totalPages > 1) { %>
  <% function pageUrl(n) {
    const u = new URLSearchParams();
    if (params.q) u.set('q', params.q);
    if (params.shelf) u.set('shelf', params.shelf);
    u.set('sort', params.sort);
    u.set('order', params.order);
    u.set('view', params.view);
    u.set('page', String(n));
    return '/library?' + u.toString();
  } %>
  <nav class="pager">
    <% if (params.page > 1) { %><a href="<%= pageUrl(params.page - 1) %>">← prev</a><% } %>
    <span class="hint">page <%= params.page %> / <%= totalPages %></span>
    <% if (params.page < totalPages) { %><a href="<%= pageUrl(params.page + 1) %>">next →</a><% } %>
  </nav>
<% } %>

<%- include('_footer') %>
