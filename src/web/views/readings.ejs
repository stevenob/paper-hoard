<% const pageTitle = 'Currently reading' %>
<%- include('_header') %>

<h1>📖 Currently reading</h1>

<% if (active.length === 0) { %>
  <p class="hint">Nobody is mid-book right now. Open a copy in the library and hit "Start reading" to add it here.</p>
<% } else { %>
  <ul class="reading-list">
    <% active.forEach(function(r) {
      const cover = r.copy.coverPath ? '/uploads/' + r.copy.coverPath : r.copy.book.thumbnailUrl;
      const days = Math.max(1, Math.round((Date.now() - new Date(r.startedAt).getTime()) / (24*60*60*1000)));
    %>
      <li class="reading-item">
        <a href="/library/copy/<%= r.copy.id %>" class="reading-cover" aria-label="<%= r.copy.book.title %>">
          <% if (cover) { %><img src="<%= cover %>" alt=""><% } else { %><div class="poster-fallback"><span><%= r.copy.book.title %></span></div><% } %>
        </a>
        <div class="reading-meta">
          <strong><a href="/library/copy/<%= r.copy.id %>"><%= r.copy.book.title %></a></strong>
          <span class="hint">by <%= r.copy.book.authors.join(', ') || 'Unknown' %></span>
          <span class="hint"><strong><%= r.user.displayName %></strong> · day <%= days %> · started <%= new Date(r.startedAt).toISOString().slice(0,10) %></span>
          <% if (activeUser && activeUser.id === r.userId) { %>
            <form method="post" action="/readings/<%= r.id %>/finish" class="reading-finish-form">
              <label class="hint" style="display:inline-flex;gap:.4rem;align-items:center;">
                <input type="checkbox" name="logCompletion" value="on" checked /> Log a completion
              </label>
              <label class="hint">Rating
                <select name="rating">
                  <option value="">—</option>
                  <% for (let s = 5; s >= 1; s--) { %><option value="<%= s %>"><%= s %>★</option><% } %>
                </select>
              </label>
              <button type="submit">Mark finished</button>
            </form>
            <form method="post" action="/readings/<%= r.id %>/delete" style="display:inline" onsubmit="return confirm('Drop this reading without recording it?')">
              <button type="submit" class="link">drop</button>
            </form>
          <% } %>
        </div>
      </li>
    <% }) %>
  </ul>
<% } %>

<% if (finished.length > 0) { %>
  <h2>Recently finished</h2>
  <ul class="reading-list reading-list-finished">
    <% finished.forEach(function(r) { %>
      <li>
        <strong><%= r.user.displayName %></strong> finished
        <a href="/library/copy/<%= r.copy.id %>"><em><%= r.copy.book.title %></em></a>
        <span class="hint">on <%= new Date(r.finishedAt).toISOString().slice(0,10) %>
          (started <%= new Date(r.startedAt).toISOString().slice(0,10) %>)</span>
      </li>
    <% }) %>
  </ul>
<% } %>

<%- include('_footer') %>
