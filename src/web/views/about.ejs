<% const pageTitle = 'About' %>
<%- include('_header') %>

<h1>About this Paper Hoard</h1>

<table class="data">
  <tbody>
    <tr><td data-label="Image tag"><strong>Image tag</strong></td><td data-label=""><code><%= imageTag %></code></td></tr>
    <tr><td data-label="Git SHA"><strong>Git SHA</strong></td><td data-label=""><code><%= gitSha %></code> <% if (gitSha && gitSha !== 'dev') { %>(<a href="<%= repoUrl %>/commit/<%= gitSha %>">view</a>)<% } %></td></tr>
    <tr><td data-label="Node.js"><strong>Node.js</strong></td><td data-label=""><%= nodeVersion %></td></tr>
    <tr><td data-label="Process uptime"><strong>Uptime</strong></td><td data-label=""><%= uptimeSec %> s</td></tr>
    <tr><td data-label="DB"><strong>Database</strong></td><td data-label=""><%= dbOk ? '✅ ok' : '❌ unreachable' %></td></tr>
  </tbody>
</table>

<h2>Counts</h2>
<table class="data">
  <tbody>
    <tr><td data-label=""><strong>Libraries</strong></td><td data-label=""><%= counts.libraries %></td></tr>
    <tr><td data-label=""><strong>Users</strong></td><td data-label=""><%= counts.users %></td></tr>
    <tr><td data-label=""><strong>Books</strong></td><td data-label=""><%= counts.books %></td></tr>
    <tr><td data-label=""><strong>Physical copies</strong></td><td data-label=""><%= counts.copies %></td></tr>
    <tr><td data-label=""><strong>Trophies</strong></td><td data-label=""><%= counts.trophies %></td></tr>
    <tr><td data-label=""><strong>Completions</strong></td><td data-label=""><%= counts.completions %></td></tr>
    <tr><td data-label=""><strong>Audit log entries</strong></td><td data-label=""><a href="/audit"><%= counts.auditLog %></a></td></tr>
  </tbody>
</table>

<h2>Discord channel posts</h2>
<% if (!library) { %>
  <p class="hint">No library exists yet.</p>
<% } else if (!activeUser) { %>
  <p class="hint">Log in to manage Discord posts.</p>
<% } else { %>
  <p>When set, every book add (web or Discord) optionally posts a rich embed to this channel — cover, rating, ISBN, and links to Goodreads / StoryGraph / Amazon / Bookshop / Open Library.</p>
  <form method="post" action="/libraries/<%= library.id %>/notify-channel" class="stacked">
    <label>Discord channel ID
      <input name="channelId" value="<%= library.notifyChannelId || '' %>" placeholder="e.g. 1489048099606364212" inputmode="numeric" maxlength="30" />
    </label>
    <p class="hint">In Discord: Settings → Advanced → Developer Mode on, then right-click the channel → Copy Channel ID. Leave blank to disable. Smaug must be in the server and have permission to post in the channel.</p>
    <button type="submit"><%= library.notifyChannelId ? 'Update' : 'Save' %></button>
  </form>
<% } %>

<h2>Backup &amp; export</h2>
<p class="hint">A daily JSON backup of every library is written to the <code>BACKUPS_DIR</code> volume (30-day retention). For one-off downloads, use the buttons below.</p>
<p>
  <a class="button" href="/library/export.csv">📊 Download CSV</a>
  <a class="button" href="/library/export.json">📦 Download JSON</a>
  <% if (activeUser) { %>
    <button type="button" id="btn-backup-now">💾 Run backup now</button>
  <% } %>
</p>
<p class="hint">CSV is one row per active copy with shelves joined by <code>;</code>. JSON is a full snapshot suitable for restore (books + copies + shelves + trophies + completions).</p>
<div id="backup-status" class="hint"></div>
<ul id="backup-list" class="hint" style="margin-top:.25rem;"></ul>
<script>
  (function() {
    const list = document.getElementById('backup-list');
    const status = document.getElementById('backup-status');
    const btn = document.getElementById('btn-backup-now');

    function fmtBytes(b) {
      if (b < 1024) return b + ' B';
      if (b < 1024 * 1024) return (b / 1024).toFixed(1) + ' KB';
      return (b / 1024 / 1024).toFixed(2) + ' MB';
    }
    async function refresh() {
      try {
        const res = await fetch('/library/backups.json');
        const json = await res.json();
        list.innerHTML = '';
        if (!json.backups || json.backups.length === 0) {
          status.textContent = json.dirMissing
            ? 'BACKUPS_DIR doesn\u2019t exist yet — first scheduled backup will create it ~60s after server start.'
            : 'No backup files yet.';
          return;
        }
        status.textContent = json.backups.length + ' backup(s) on disk · ' + (json.dir || '');
        json.backups.slice(0, 10).forEach(function(b) {
          const li = document.createElement('li');
          li.textContent = b.name + ' · ' + fmtBytes(b.size) + ' · ' + b.mtime.replace('T', ' ').slice(0, 16);
          list.appendChild(li);
        });
      } catch (err) { /* ignore */ }
    }
    if (btn) btn.addEventListener('click', async function() {
      btn.disabled = true;
      btn.textContent = 'Running…';
      try {
        await fetch('/library/backup-now', { method: 'POST' });
        await refresh();
      } finally {
        btn.disabled = false;
        btn.textContent = '💾 Run backup now';
      }
    });
    refresh();
  })();
</script>

<h2>Public share link</h2>
<% if (!library) { %>
  <p class="hint">No library exists yet.</p>
<% } else if (!activeUser) { %>
  <p class="hint">Log in to manage the share link.</p>
<% } else if (!library.publicSlug) { %>
  <p>The library is currently <strong>private</strong>. Enable a public read-only link to share with friends without giving them edit access.</p>
  <form method="post" action="/libraries/<%= library.id %>/share/enable">
    <button type="submit">Enable public share link</button>
  </form>
<% } else { %>
  <% const shareUrl = (webBaseUrl ? webBaseUrl.replace(/\/$/, '') : '') + '/share/' + library.publicSlug %>
  <p>The library is <strong>public</strong> at:</p>
  <p><code><%= shareUrl %></code> · <a href="/share/<%= library.publicSlug %>" target="_blank" rel="noopener">open</a></p>
  <form method="post" action="/libraries/<%= library.id %>/share/regenerate" style="display:inline" onsubmit="return confirm('Regenerate the link? The old URL will stop working.')">
    <button type="submit">Regenerate</button>
  </form>
  <form method="post" action="/libraries/<%= library.id %>/share/disable" style="display:inline" onsubmit="return confirm('Disable public sharing?')">
    <button type="submit" class="danger">Disable</button>
  </form>
<% } %>

<h2>Links</h2>
<ul>
  <li><a href="<%= repoUrl %>">Source on GitHub</a></li>
  <li><a href="<%= ghcrUrl %>">Container image on GHCR</a></li>
</ul>

<%- include('_footer') %>
