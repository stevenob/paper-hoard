<% const pageTitle = book.title %>
<%- include('_header') %>

<p><a href="/library">← back to library</a> <% if (activeUser) { %>· <a href="/books/<%= book.id %>/edit">edit metadata</a><% } %></p>

<article class="book-detail">
  <% if (book.thumbnailUrl) { %>
    <img class="cover" src="<%= book.thumbnailUrl %>" alt="">
  <% } %>
  <div class="book-meta">
    <h1><%= book.title %></h1>
    <p class="hint"><% if (book.authors && book.authors.length > 0) { %><% book.authors.forEach(function(a, i) { %><% if (i > 0) { %>, <% } %><% const slug = authorSlug(a); %><% if (slug) { %><a href="/authors/<%= slug %>"><%= a %></a><% } else { %><%= a %><% } %><% }) %><% } else { %>Unknown author<% } %></p>
    <% if (book.publisher || book.publishedAt) { %>
      <p class="hint"><%= [book.publisher, book.publishedAt].filter(Boolean).join(' • ') %></p>
    <% } %>
    <% if (book.isbn13) { %><p class="hint">ISBN <%= book.isbn13 %></p><% } %>
    <% if (book.olRatingAvg !== null && book.olRatingCount > 0) { %>
      <p class="hint">⭐ <strong><%= book.olRatingAvg.toFixed(2) %></strong> <span class="hint">(Open Library, <%= book.olRatingCount %> rating<%= book.olRatingCount === 1 ? '' : 's' %>)</span></p>
    <% } %>
    <p class="external-links">
      <% const q = book.isbn13 || book.title %>
      <% if (q) { %>
        <a class="pill pill-tag" href="https://www.goodreads.com/search?q=<%= encodeURIComponent(q) %>" target="_blank" rel="noopener">Goodreads ↗</a>
        <a class="pill pill-tag" href="https://app.thestorygraph.com/browse?search_term=<%= encodeURIComponent(q) %>" target="_blank" rel="noopener">StoryGraph ↗</a>
        <% if (book.isbn13) { %>
          <a class="pill pill-tag" href="https://www.librarything.com/isbn/<%= book.isbn13 %>" target="_blank" rel="noopener">LibraryThing ↗</a>
          <a class="pill pill-tag" href="https://openlibrary.org/isbn/<%= book.isbn13 %>" target="_blank" rel="noopener">Open Library ↗</a>
          <a class="pill pill-tag" href="https://bookshop.org/search?keywords=<%= book.isbn13 %>" target="_blank" rel="noopener">Bookshop ↗</a>
        <% } %>
      <% } %>
    </p>
    <% if (shelves && shelves.length > 0) { %>
      <p class="tag-chips">
        On shelves:
        <% shelves.forEach(function(s) { %>
          <a href="/shelves/<%= s.slug %>" class="pill pill-tag"><%= s.name %></a>
        <% }) %>
      </p>
    <% } %>
  </div>
</article>

<h2>Physical copies (<%= copies.length %>)</h2>
<% if (copies.length === 0) { %>
  <p class="hint">No physical copies in the library yet.</p>
<% } else { %>
  <ul class="copy-list">
    <% copies.forEach(function(c) { %>
      <li>
        <a href="/library/copy/<%= c.id %>">
          <strong><%= c.edition || 'edition?' %></strong> · <%= c.condition || 'condition?' %>
        </a>
        <span class="hint">added <%= c.addedAt.toISOString().slice(0,10) %></span>
      </li>
    <% }) %>
  </ul>
<% } %>

<h2>Trophy</h2>
<% if (trophies.length === 0) { %>
  <p class="hint">Not on the Trophy List.</p>
<% } else { %>
  <% trophies.forEach(function(t) { %>
    <p>🏆 Requested by <strong><%= t.requestedBy.displayName %></strong> · priority <%= t.priority %><% if (t.desiredFormat) { %> · wants <%= t.desiredFormat %><% } %><% if (t.reason) { %> — <%= t.reason %><% } %></p>
  <% }) %>
<% } %>

<h2>Completions (<%= completions.length %>)</h2>
<% if (completions.length === 0) { %>
  <p class="hint">No one has logged completing this book.</p>
<% } else { %>
  <ul>
    <% completions.forEach(function(c) { %>
      <li><%= c.user.displayName %> finished the <%= c.mediaType %><%= c.completedOn ? ' on ' + c.completedOn.toISOString().slice(0,10) : '' %><%= c.rating ? ' • ' + c.rating + '★' : '' %><%= c.notes ? ' — ' + c.notes : '' %></li>
    <% }) %>
  </ul>
<% } %>

<%- include('_footer') %>
