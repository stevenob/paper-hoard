<% const pageTitle = 'Audit log' %>
<%- include('_header') %>

<h1>Audit log</h1>
<p class="hint"><%= total %> entries total. Page <%= page %> of <%= totalPages %>.</p>

<% if (rows.length === 0) { %>
  <p>No activity yet.</p>
<% } else { %>
  <table class="data">
    <thead>
      <tr><th>When</th><th>Who</th><th>Action</th><th>Entity</th><th>ID</th><th>Details</th></tr>
    </thead>
    <tbody>
      <% rows.forEach(function(r) { %>
        <tr>
          <td data-label="When"><%= r.createdAt.toISOString().replace('T',' ').slice(0,19) %></td>
          <td data-label="Who"><%= r.userId ? (usersById.get(r.userId) ? usersById.get(r.userId).displayName : r.userId) : 'system' %></td>
          <td data-label="Action"><%= r.action %></td>
          <td data-label="Entity"><%= r.entity %></td>
          <td data-label="ID"><code><%= r.entityId %></code></td>
          <td data-label="Details"><% if (r.details) { %><code><%= JSON.stringify(r.details) %></code><% } %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <% if (totalPages > 1) { %>
    <nav class="pager">
      <% if (page > 1) { %><a href="/audit?page=<%= page - 1 %>">← prev</a><% } %>
      <span class="hint">page <%= page %> / <%= totalPages %></span>
      <% if (page < totalPages) { %><a href="/audit?page=<%= page + 1 %>">next →</a><% } %>
    </nav>
  <% } %>
<% } %>

<%- include('_footer') %>
