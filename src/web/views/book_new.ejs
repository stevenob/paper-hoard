<% const pageTitle = 'Add a book manually' %>
<%- include('_header') %>

<%- include('_page_hero', {
  icon: '✍️',
  title: 'Add a book manually',
  blurb: "Use this when Google Books and Open Library don't know the book — vintage editions, self-published, regional reprints. Creates a Book row marked source: manual plus a physical copy.",
  back: { href: '/library', label: '← back to library' }
}) %>

<% if (error) { %><p class="error"><%= error %></p><% } %>
<% if (!activeUser) { %><p class="notice">You need to <a href="/auth/login">log in</a> to add a book.</p><% } %>

<form method="post" action="/books/new" class="form-card">
  <fieldset <%= activeUser ? '' : 'disabled' %> style="border:0;padding:0;margin:0;min-width:0;">
    <div class="form-section">
      <h3 class="form-section-h">Identity</h3>
      <div class="form-row full">
        <div>
          <label>Title <span class="hint">(required)</span></label>
          <input type="text" name="title" value="<%= prefill.title || '' %>" required maxlength="500" autofocus />
        </div>
      </div>
      <div class="form-row">
        <div>
          <label>Authors <span class="hint">(comma-separated)</span></label>
          <input type="text" name="authors" value="<%= prefill.authors || '' %>" maxlength="1000" placeholder="Andy Weir, Co-Author Name" />
        </div>
        <div>
          <label>ISBN-13 <span class="hint">(optional)</span></label>
          <input type="text" name="isbn13" value="<%= prefill.isbn13 || '' %>" maxlength="13" inputmode="numeric" placeholder="9780593135204" />
        </div>
      </div>
    </div>
    <div class="form-section">
      <h3 class="form-section-h">Publishing</h3>
      <div class="form-row three">
        <div>
          <label>Publisher</label>
          <input type="text" name="publisher" value="<%= prefill.publisher || '' %>" maxlength="200" />
        </div>
        <div>
          <label>Published</label>
          <input type="text" name="publishedAt" value="<%= prefill.publishedAt || '' %>" placeholder="2021-05-04 or 1973" maxlength="50" />
        </div>
        <div>
          <label>Edition</label>
          <select name="edition">
            <option value="">—</option>
            <% editions.forEach(function(e) { %>
              <option value="<%= e %>"><%= e %></option>
            <% }) %>
          </select>
        </div>
      </div>
    </div>
    <div class="form-section">
      <h3 class="form-section-h">Series <span class="hint">(optional)</span></h3>
      <div class="form-row">
        <div>
          <label>Series name</label>
          <input type="text" name="seriesName" value="<%= prefill.seriesName || '' %>" maxlength="200" placeholder="Mistborn" list="series-names-list" autocomplete="off" />
          <datalist id="series-names-list">
            <% (typeof seriesNames !== 'undefined' ? seriesNames : []).forEach(function(s) { %>
              <option value="<%= s %>"></option>
            <% }) %>
          </datalist>
        </div>
        <div>
          <label>Volume number</label>
          <input type="number" name="seriesPosition" value="<%= prefill.seriesPosition || '' %>" step="0.1" min="0" max="999" placeholder="1" />
        </div>
      </div>
    </div>
    <div class="form-section">
      <h3 class="form-section-h">This copy</h3>
      <div class="form-row">
        <div>
          <label>Condition</label>
          <select name="condition">
            <option value="">—</option>
            <option value="new">new</option>
            <option value="like-new">like-new</option>
            <option value="good">good</option>
            <option value="fair">fair</option>
            <option value="poor">poor</option>
          </select>
        </div>
        <div>
          <label>Add to shelf <span class="hint">(optional)</span></label>
          <select name="shelfId">
            <option value="">— No shelf —</option>
            <% (typeof shelves !== 'undefined' ? shelves : []).forEach(function(s) { %>
              <option value="<%= s.id %>" <%= prefill.shelfId === s.id ? 'selected' : '' %>><%= s.name %><% if (s._count && s._count.copies) { %> (<%= s._count.copies %>)<% } %></option>
            <% }) %>
          </select>
        </div>
      </div>
    </div>
    <div class="form-section">
      <h3 class="form-section-h">Cover</h3>
      <div class="form-row full">
        <div>
          <label>Cover image URL <span class="hint">(optional)</span></label>
          <input type="text" name="thumbnailUrl" value="" maxlength="2000" placeholder="https://…" />
        </div>
      </div>
    </div>
    <div class="form-actions">
      <button type="submit" class="primary">＋ Add book and copy</button>
      <a href="/library" class="cancel">cancel</a>
    </div>
  </fieldset>
</form>

<%- include('_footer') %>
