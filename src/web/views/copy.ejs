<% const pageTitle = copy.book.title %>
<%- include('_header') %>

<p><a href="/library">← back to library</a> · <a href="/books/<%= copy.bookId %>">all about this book →</a></p>

<article class="book-detail">
  <% const cover = copy.coverPath ? '/uploads/' + copy.coverPath : copy.book.thumbnailUrl %>
  <% if (cover) { %>
    <img class="cover" src="<%= cover %>" alt="">
  <% } %>
  <div class="book-meta">
    <h1><%= copy.book.title %></h1>
    <p class="hint"><% if (copy.book.authors && copy.book.authors.length > 0) { %><% copy.book.authors.forEach(function(a, i) { %><% if (i > 0) { %>, <% } %><% const slug = authorSlug(a); %><% if (slug) { %><a href="/authors/<%= slug %>"><%= a %></a><% } else { %><%= a %><% } %><% }) %><% } else { %>Unknown author<% } %></p>
    <% if (copy.book.publisher || copy.book.publishedAt) { %>
      <p class="hint"><%= [copy.book.publisher, copy.book.publishedAt].filter(Boolean).join(' • ') %></p>
    <% } %>
    <% if (copy.book.isbn13) { %><p class="hint">ISBN <%= copy.book.isbn13 %></p><% } %>
    <p class="hint">Added <%= copy.addedAt.toISOString().slice(0,10) %></p>
    <% if (copy.deletedAt) { %>
      <p class="notice">This copy is in the Trash (deleted <%= new Date(copy.deletedAt).toISOString().slice(0,10) %>).
        <% if (activeUser) { %>
          <form method="post" action="/library/copy/<%= copy.id %>/restore" style="display:inline">
            <button type="submit">Restore</button>
          </form>
        <% } %>
      </p>
    <% } %>
  </div>
</article>

<h2>Cover photo</h2>
<% if (!activeUser) { %>
  <p class="hint"><a href="/auth/login">Log in</a> to upload a cover.</p>
<% } else { %>
  <form method="post" action="/library/copy/<%= copy.id %>/cover" enctype="multipart/form-data" class="upload-form">
    <input type="file" name="cover" accept="image/jpeg,image/png,image/webp,image/gif" required />
    <button type="submit"><%= copy.coverPath ? 'Replace' : 'Upload' %> cover</button>
  </form>
  <p class="hint">JPEG, PNG, WebP, or GIF. Max 5MB. Replaces the metadata thumbnail on this and the book pages.</p>
  <% if (copy.coverPath) { %>
    <form method="post" action="/library/copy/<%= copy.id %>/cover/delete" onsubmit="return confirm('Remove the uploaded cover?')">
      <button type="submit" class="danger">Remove uploaded cover</button>
    </form>
  <% } %>
<% } %>

<h2>Edit this copy</h2>

<% if (!activeUser) { %>
  <p class="notice">You need to <a href="/auth/login">log in</a> to edit.</p>
<% } %>

<form method="post" action="/library/copy/<%= copy.id %>/edit" class="stacked">
  <fieldset <%= activeUser ? '' : 'disabled' %>>
    <label>Condition
      <select name="condition">
        <option value="">—</option>
        <% conditions.forEach(function(c) { %>
          <option value="<%= c %>" <%= copy.condition === c ? 'selected' : '' %>><%= c %></option>
        <% }) %>
      </select>
    </label>
    <label>Edition
      <select name="edition">
        <option value="">—</option>
        <% editions.forEach(function(e) { %>
          <option value="<%= e %>" <%= copy.edition === e ? 'selected' : '' %>><%= e %></option>
        <% }) %>
      </select>
    </label>
    <label>Notes
      <textarea name="notes" rows="3" maxlength="2000"><%= copy.notes || '' %></textarea>
    </label>
    <button type="submit">Save</button>
  </fieldset>
</form>

<h2>Shelves</h2>
<% if (copy.shelves && copy.shelves.length > 0) { %>
  <p class="tag-chips">
    <% copy.shelves.forEach(function(sc) { %>
      <span class="pill pill-tag">
        <a href="/shelves/<%= sc.shelf.slug %>"><%= sc.shelf.name %></a>
        <% if (activeUser) { %>
          <form method="post" action="/library/copy/<%= copy.id %>/shelves/<%= sc.shelf.id %>/delete" style="display:inline">
            <button type="submit" title="Remove from shelf" aria-label="Remove from shelf"
              style="background:transparent;border:0;color:inherit;cursor:pointer;padding:0 0 0 .25rem;">×</button>
          </form>
        <% } %>
      </span>
    <% }) %>
  </p>
<% } else { %>
  <p class="hint">Not on any shelves.</p>
<% } %>
<% if (activeUser) { %>
  <form method="post" action="/library/copy/<%= copy.id %>/shelves" class="add-tag">
    <input list="shelf-options" name="name" placeholder="Add to shelf (existing or new)" maxlength="100" required />
    <button type="submit">+</button>
  </form>
  <datalist id="shelf-options">
    <% (libraryShelves || []).forEach(function(s) { %>
      <option value="<%= s.name %>"></option>
    <% }) %>
  </datalist>
<% } %>

<% if (activeUser) { %>
  <h2>Danger zone</h2>
  <% if (copy.deletedAt) { %>
    <p class="hint">Already in Trash. Use the <a href="/trash">trash page</a> to restore or delete forever.</p>
  <% } else { %>
    <form method="post" action="/library/copy/<%= copy.id %>/delete" onsubmit="return confirm('Move this copy to Trash? You can restore it for the next 30 days.')">
      <button type="submit" class="danger">Move to Trash</button>
    </form>
    <p class="hint">Soft-deleted. Restore from <a href="/trash">/trash</a> within 30 days.</p>
  <% } %>
<% } %>

<% if (completions.length > 0) { %>
  <h2>Completions of this title</h2>
  <ul>
    <% completions.forEach(function(c) { %>
      <li><%= c.user.displayName %> finished the <%= c.mediaType %><%= c.completedOn ? ' on ' + c.completedOn.toISOString().slice(0,10) : '' %><%= c.rating ? ' • ' + c.rating + '★' : '' %></li>
    <% }) %>
  </ul>
<% } %>

<%- include('_footer') %>

