<% const pageTitle = 'Scan' %>
<%- include('_header') %>

<section class="scan-hero">
  <h1>📷 Scan a book</h1>
  <p class="scan-hero-tagline">Point your phone at a barcode, upload a photo, look it up by title, or scan a printed spine sticker. Whatever's fastest.</p>

  <% if (!activeUser) { %>
    <p class="notice" style="max-width:60ch;margin:1.5rem auto 0;">You need to <a href="/auth/login">log in with Discord</a> before scanning — every scan is recorded as added by the logged-in user.</p>
  <% } %>
  <% if (!library) { %>
    <p class="notice" style="max-width:60ch;margin:1.5rem auto 0;">No family library exists yet. In Discord, run <code>/library</code> once so Smaug creates the household library, then come back here.</p>
  <% } %>

  <div class="scanner-launch-buttons">
    <button type="button" id="btn-start" class="big primary">📷 Start camera</button>
    <label class="button big" for="photo-input">🖼 Choose photo</label>
    <input type="file" id="photo-input" accept="image/*" capture="environment" hidden />
  </div>
  <p id="status" class="hint scan-status-line"></p>
  <p class="hint" id="https-warning" hidden style="max-width:60ch;margin:1rem auto 0;">
    Your browser blocked camera access. Most browsers (especially iOS Safari) require an
    <strong>https://</strong> URL or <code>localhost</code> for camera permission.
    Use the manual lookup below as a fallback.
  </p>
</section>

<!-- Fullscreen camera overlay; hidden until Start camera is tapped. -->
<div id="camera-overlay" class="camera-overlay" hidden role="dialog" aria-modal="true" aria-label="Barcode scanner">
  <div class="camera-topbar">
    <button type="button" id="btn-done" class="scan-close" aria-label="Close scanner">✕</button>
    <!-- Visually hidden but kept in the DOM: existing JS still writes the
         live status here, and screen readers still announce it. The new
         on-screen pill (#scan-pill) below the reticle mirrors this text. -->
    <span id="overlay-status">Scanning… point at the barcode on the back cover.</span>
    <div class="scan-topbar-cluster">
      <button type="button" id="btn-torch" class="ghost" aria-pressed="false" hidden title="Flashlight">💡</button>
      <button type="button" id="btn-bulk" class="ghost" aria-pressed="false" title="Bulk scan mode — auto-add new books, skip duplicates">📚</button>
    </div>
  </div>
  <div class="camera-stage">
    <video id="video" playsinline muted autoplay aria-label="Camera feed"></video>
    <!-- Single absolutely-positioned reticle. The lit area inside is just
         the box itself; the dim everywhere else is painted by a giant
         box-shadow on this element. The faint barcode ghost guide is a
         CSS ::before. -->
    <div class="camera-reticle" aria-hidden="true">
      <span class="corner tl"></span>
      <span class="corner tr"></span>
      <span class="corner bl"></span>
      <span class="corner br"></span>
      <span class="scanline"></span>
    </div>
    <!-- v3.5.9 state pill: live decode/lookup status. JS swaps the .label
         text + class to drive the pointing/decoding/ok/dup/trophy states. -->
    <div class="scan-pill" id="scan-pill" role="status" aria-live="polite">
      <span class="dot" aria-hidden="true"></span>
      <span class="label">pointing…</span>
    </div>
  </div>
  <div class="camera-toast" id="overlay-toast" hidden role="status" aria-live="polite"></div>

  <!-- Bulk-mode filmstrip: shown only when bulk mode is on. The runtime
       creates .bulk-tile elements inside #filmstrip-rail when books are
       auto-added; the scaffolding is rendered the first time bulk mode
       toggles on (see scan.ejs JS). -->
  <div id="bulk-queue" class="bulk-queue" hidden aria-live="polite" aria-label="Recently added"></div>

  <!-- Confirm card shown after a successful barcode decode + lookup. -->
  <div id="confirm-card" class="confirm-card" hidden role="dialog" aria-label="Confirm scanned book">
    <img id="confirm-cover" alt="" class="confirm-cover" hidden />
    <div class="confirm-cover-fallback" id="confirm-cover-fallback" hidden></div>
    <h2 class="confirm-title" id="confirm-title">…</h2>
    <p class="confirm-author" id="confirm-author"></p>
    <p class="confirm-meta" id="confirm-meta"></p>
    <p id="confirm-trophy" class="confirm-flag trophy" hidden></p>
    <p id="confirm-dup" class="confirm-flag dup" hidden></p>

    <!-- Inline edit form: hidden by default, auto-opens when authors[]
         comes back empty so the user has to fix the most-common gap
         before the Add button does anything. Generic ✏️ link below
         opens it for any other field tweak. -->
    <details id="confirm-edit" class="confirm-edit">
      <summary>✏️ Edit before adding</summary>
      <p id="confirm-edit-author-warning" class="confirm-flag dup" hidden>
        ⚠️ No author found in the source data. Add one before confirming.
      </p>
      <label>Title <input id="edit-title" maxlength="500" /></label>
      <label>Authors <span class="hint">(comma-separated)</span>
        <input id="edit-authors" maxlength="1000" placeholder="Andy Weir" />
      </label>
      <label>Publisher <input id="edit-publisher" maxlength="200" /></label>
      <label>Edition
        <select id="edit-edition">
          <option value="">—</option>
          <option value="hardcover">hardcover</option>
          <option value="paperback">paperback</option>
          <option value="mass-market">mass-market</option>
          <option value="special">special</option>
          <option value="signed">signed</option>
          <option value="boxset">boxset</option>
          <option value="other">other</option>
        </select>
      </label>
    </details>

    <div class="confirm-actions">
      <button type="button" id="btn-confirm-add" class="primary big">📚 Add to library</button>
      <div class="confirm-secondary">
        <button type="button" id="btn-confirm-trophy" class="link-trophy">🏆 Trophy</button>
        <button type="button" id="btn-confirm-share" class="link-discord" hidden>💬 Discord</button>
        <button type="button" id="btn-confirm-skip" class="link-skip">Skip</button>
      </div>
    </div>
  </div>

  <!-- Fallback card: shown when an ISBN lookup found nothing in either
       Google Books or Open Library. Lets the user retry by title without
       leaving the camera overlay, and falls through to /books/new for
       truly obscure books. -->
  <div id="fallback-card" class="confirm-card fallback-card" hidden role="dialog" aria-label="Lookup failed — try title">
    <h2 class="confirm-title">Couldn't find that book</h2>
    <p class="confirm-meta" id="fallback-isbn"></p>
    <p class="hint">Search by title instead — vintage and self-published books often aren't in Google Books or Open Library.</p>
    <form id="fallback-form" class="stacked">
      <label>Title <input id="fallback-title" name="title" autocomplete="off" required maxlength="200" /></label>
      <label>Author <input id="fallback-author" name="author" autocomplete="off" placeholder="Optional — narrows search" maxlength="200" /></label>
      <div class="confirm-actions">
        <button type="submit" class="primary big">🔍 Search by title</button>
        <div class="confirm-secondary">
          <a id="fallback-manual-link" class="link-trophy" href="/books/new">✍️ Add manually</a>
          <button type="button" id="btn-fallback-skip" class="link-skip">Skip</button>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="scan-grid">
  <section class="scan-card">
    <h2>Or look up manually</h2>
    <div id="saved-scans" hidden></div>
    <form id="manual-form" class="stacked">
      <label>ISBN <input id="manual-isbn" name="isbn" placeholder="9780593135204" autocomplete="off" inputmode="numeric" /></label>
      <p class="hint">— or —</p>
      <label>Title <input id="manual-title" name="title" placeholder="Project Hail Mary" autocomplete="off" /></label>
      <label>Author <input id="manual-author" name="author" placeholder="Andy Weir (optional, narrows the search)" autocomplete="off" /></label>
      <button type="submit">Look up</button>
    </form>
    <div id="results"></div>
  </section>

  <aside class="scan-card scan-recent">
    <h2>Recent additions</h2>
    <% if (recent.length === 0) { %>
      <p class="hint">Nothing yet — scan your first book on the left.</p>
    <% } else { %>
      <ul class="recent-list">
        <% recent.forEach(function(c) { %>
          <li>
            <a href="/library/copy/<%= c.id %>"><strong><%= c.book.title %></strong></a>
            <div class="hint"><%= c.book.authors.join(', ') %> · added by <%= c.addedBy.displayName %></div>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </aside>
</div>

<!-- ZXing barcode scanner: vendored UMD bundle, served from this app. -->
<script src="/static/zxing-browser.min.js"></script>
<script>
  (function() {
    const video = document.getElementById('video');
    const btnStart = document.getElementById('btn-start');
    const btnDone = document.getElementById('btn-done');
    const status = document.getElementById('status');
    const overlay = document.getElementById('camera-overlay');
    const overlayStatus = document.getElementById('overlay-status');
    const overlayToast = document.getElementById('overlay-toast');
    const confirmCard = document.getElementById('confirm-card');
    const confirmCover = document.getElementById('confirm-cover');
    const confirmCoverFallback = document.getElementById('confirm-cover-fallback');
    const confirmTitle = document.getElementById('confirm-title');
    const confirmAuthor = document.getElementById('confirm-author');
    const confirmMeta = document.getElementById('confirm-meta');
    const confirmTrophy = document.getElementById('confirm-trophy');
    const confirmDup = document.getElementById('confirm-dup');
    const btnConfirmAdd = document.getElementById('btn-confirm-add');
    const btnConfirmShare = document.getElementById('btn-confirm-share');
    const btnConfirmSkip = document.getElementById('btn-confirm-skip');
    const btnConfirmTrophy = document.getElementById('btn-confirm-trophy');
    const confirmEdit = document.getElementById('confirm-edit');
    const editTitleEl = document.getElementById('edit-title');
    const editAuthorsEl = document.getElementById('edit-authors');
    const editPublisherEl = document.getElementById('edit-publisher');
    const editEditionEl = document.getElementById('edit-edition');
    const editAuthorWarning = document.getElementById('confirm-edit-author-warning');
    const httpsWarning = document.getElementById('https-warning');
    const results = document.getElementById('results');
    const manualForm = document.getElementById('manual-form');

    const hasZxing = typeof ZXingBrowser !== 'undefined';
    if (!hasZxing) {
      status.textContent = 'Barcode library failed to load — manual entry still works.';
      btnStart.disabled = true;
    }

    let reader = null;
    let controls = null;
    let lastSubmitted = null;
    let lastSubmittedAt = 0;
    let busy = false;
    let toastTimer = null;
    let pendingConfirm = null;
    let mediaStream = null;
    let wakeLock = null;
    let pendingDecode = null;
    let pendingDecodeAt = 0;
    let reticleFlashTimer = null;
    const CONFIRM_WINDOW_MS = 600;
    const btnTorch = document.getElementById('btn-torch');
    const btnBulk = document.getElementById('btn-bulk');
    const bulkQueue = document.getElementById('bulk-queue');
    const reticleEl = document.querySelector('.camera-reticle');

    let bulkMode = false;
    let lastBulkCopyId = null;
    let bulkScaffoldRendered = false;

    btnBulk.addEventListener('click', function() {
      bulkMode = !bulkMode;
      btnBulk.setAttribute('aria-pressed', String(bulkMode));
      btnBulk.classList.toggle('active', bulkMode);
      if (bulkMode) {
        ensureBulkScaffold();
        bulkQueue.hidden = false;
        showToast('📚 Bulk mode: new books auto-add, duplicates skip', true);
      } else {
        // Per v3.5.9 design: filmstrip is bulk-only. Hide it when bulk
        // turns off; tiles persist in the DOM for next time.
        bulkQueue.hidden = true;
        showToast('Bulk mode off — back to confirm-each-scan', true);
      }
    });

    function ensureBulkScaffold() {
      if (bulkScaffoldRendered) return;
      bulkQueue.innerHTML =
        '<div class="filmstrip-meta">' +
          '<span id="filmstrip-counts">📚 0 scanned</span>' +
          '<button type="button" id="filmstrip-undo" class="undo" disabled>↶ undo last</button>' +
        '</div>' +
        '<div id="filmstrip-rail" class="filmstrip-rail"></div>';
      const undoBtn = document.getElementById('filmstrip-undo');
      undoBtn.addEventListener('click', undoLastBulk);
      bulkScaffoldRendered = true;
    }

    let bulkCounts = { scanned: 0, new: 0, dup: 0, trophy: 0 };
    function updateFilmstripCounts() {
      const el = document.getElementById('filmstrip-counts');
      if (!el) return;
      const parts = ['📚 ' + bulkCounts.scanned + ' scanned'];
      if (bulkCounts.new) parts.push(bulkCounts.new + ' new');
      if (bulkCounts.dup) parts.push(bulkCounts.dup + ' dup');
      if (bulkCounts.trophy) parts.push(bulkCounts.trophy + ' ⭐');
      el.textContent = parts.join(' · ');
    }

    /**
     * Push a colored cover tile onto the filmstrip. Replaces the v3.5.8
     * .bulk-chip with a richer thumbnail-based tile so users can verify
     * what was just added at a glance.
     */
    function pushBulkTile(book, kind, copyId) {
      ensureBulkScaffold();
      const rail = document.getElementById('filmstrip-rail');
      if (!rail) return;
      const tile = document.createElement(copyId ? 'a' : 'span');
      tile.className = 'bulk-tile fresh ' + (kind || 'new');
      if (copyId) {
        tile.href = '/library/copy/' + copyId;
        tile.target = '_blank';
        tile.rel = 'noopener';
        tile.dataset.copyId = copyId;
      }
      const cover = book && book.thumbnailUrl;
      const titleSafe = (book && book.title || '?').slice(0, 60);
      tile.title = titleSafe + (kind === 'dup' ? ' (already owned)' : kind === 'trophy' ? ' (trophy)' : '');
      if (cover) {
        const img = document.createElement('img');
        img.src = cover;
        img.alt = '';
        img.loading = 'lazy';
        tile.appendChild(img);
      } else {
        const lab = document.createElement('span');
        lab.className = 'tile-label';
        lab.textContent = titleSafe.slice(0, 24);
        tile.appendChild(lab);
      }
      // Newest tile slides in from the right edge.
      rail.appendChild(tile);
      rail.scrollTo({ left: rail.scrollWidth, behavior: 'smooth' });
      // Drop the .fresh class after the slide-in animation finishes.
      setTimeout(function() { tile.classList.remove('fresh'); }, 400);
      // Cap DOM at 50 tiles so very long sessions stay responsive.
      while (rail.children.length > 50) rail.removeChild(rail.firstChild);
      // Counts.
      bulkCounts.scanned++;
      if (kind === 'trophy') bulkCounts.trophy++;
      else if (kind === 'dup') bulkCounts.dup++;
      else bulkCounts.new++;
      updateFilmstripCounts();
      // Track the last addable tile for the undo button.
      if (copyId) {
        lastBulkCopyId = copyId;
        const u = document.getElementById('filmstrip-undo');
        if (u) u.disabled = false;
      }
    }

    /**
     * Undo the last bulk-add by trashing the most recent PhysicalCopy. Uses
     * the existing /library/copy/:id/delete endpoint. Removes the tile
     * from the filmstrip on success.
     */
    async function undoLastBulk() {
      if (!lastBulkCopyId) return;
      const undoBtn = document.getElementById('filmstrip-undo');
      if (undoBtn) undoBtn.disabled = true;
      const copyId = lastBulkCopyId;
      try {
        const res = await fetch('/library/copy/' + copyId + '/delete', { method: 'POST' });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        // Remove tile + decrement counts.
        const rail = document.getElementById('filmstrip-rail');
        if (rail) {
          const matches = rail.querySelectorAll('[data-copy-id="' + copyId + '"]');
          for (let i = 0; i < matches.length; i++) matches[i].remove();
        }
        bulkCounts.scanned = Math.max(0, bulkCounts.scanned - 1);
        bulkCounts.new = Math.max(0, bulkCounts.new - 1);
        updateFilmstripCounts();
        showToast('↶ Undone', true);
        lastBulkCopyId = null;
      } catch (err) {
        showToast('Undo failed: ' + (err.message || err), false);
        if (undoBtn) undoBtn.disabled = false;
      }
    }

    function flashReticle(state) {
      if (!reticleEl) return;
      reticleEl.classList.remove('detect', 'lock');
      // Forcing reflow re-triggers the animation if we flash twice in a row.
      void reticleEl.offsetWidth;
      reticleEl.classList.add(state);
      if (reticleFlashTimer) clearTimeout(reticleFlashTimer);
      reticleFlashTimer = setTimeout(function() { reticleEl.classList.remove(state); }, 600);
    }

    function setStatus(msg) {
      status.textContent = msg || '';
      if (msg) overlayStatus.textContent = msg;
    }

    /**
     * Drive the on-screen state pill below the reticle. States: idle,
     * searching, ok, dup, trophy, err. Auto-resets to "pointing…" after
     * 2s for transient outcome states (ok/dup/trophy/err).
     */
    const scanPill = document.getElementById('scan-pill');
    let pillResetTimer = null;
    function setPill(state, label) {
      if (!scanPill) return;
      if (pillResetTimer) { clearTimeout(pillResetTimer); pillResetTimer = null; }
      scanPill.className = 'scan-pill' + (state && state !== 'idle' ? ' ' + state : '');
      const labelEl = scanPill.querySelector('.label');
      if (labelEl) labelEl.textContent = label || 'pointing…';
      // Outcome states auto-revert; persistent states (idle/searching) stay.
      if (state === 'ok' || state === 'dup' || state === 'trophy' || state === 'err') {
        pillResetTimer = setTimeout(function() {
          if (!pendingConfirm) setPill('idle', 'pointing…');
        }, 2200);
      }
    }

    function showToast(text, ok) {
      overlayToast.textContent = text;
      overlayToast.className = 'camera-toast ' + (ok ? 'ok' : 'err');
      overlayToast.hidden = false;
      if (toastTimer) clearTimeout(toastTimer);
      toastTimer = setTimeout(function() { overlayToast.hidden = true; }, 2500);
    }

    function showConfirm(payload, originalRequest) {
      // Bulk mode: skip the confirm card. New books auto-add, duplicates
      // are flagged + skipped (no second copy created), trophy matches go
      // through the auto-add path so the trophy is correctly acquired.
      if (bulkMode) {
        const titleStr = (payload.book && payload.book.title) || 'Unknown';
        const dup = (payload.existingCopies || []).length > 0;
        if (dup && !payload.trophy) {
          showToast('⚠️ Skipped (already owned): ' + titleStr, false);
          setPill('dup', '⚠ already owned: ' + titleStr.slice(0, 40));
          // Track dup encounter on the filmstrip even though no copy was
          // created — useful so the user sees how many they re-scanned.
          pushBulkTile(payload.book, 'dup', null);
          if (navigator.vibrate) navigator.vibrate([20, 40, 20]);
          pendingConfirm = null;
          overlayStatus.textContent = 'Scanning…';
          return;
        }
        // Auto-commit. submitLookup posts to /scan and records the copy;
        // pushBulkTile is called by submitLookup once the copyId is back.
        pendingConfirm = null;
        if (navigator.vibrate) navigator.vibrate(60);
        submitLookup(originalRequest, {
          bulkTile: true,
          bypassBusy: true,
          tileBook: payload.book,
          tileKind: payload.trophy ? 'trophy' : 'new',
        });
        overlayStatus.textContent = 'Scanning…';
        return;
      }

      pendingConfirm = { payload: payload, request: originalRequest };
      const b = payload.book;
      // Drive the pill: trophy > dup > ok
      const dupCount = (payload.existingCopies || []).length;
      if (payload.trophy) {
        setPill('trophy', '🏆 trophy match');
      } else if (dupCount > 0) {
        setPill('dup', '⚠ already owned');
      } else {
        setPill('ok', '✓ ' + (b.title || 'found'));
      }
      if (b.thumbnailUrl) {
        confirmCover.src = b.thumbnailUrl;
        confirmCover.hidden = false;
        confirmCoverFallback.hidden = true;
      } else {
        confirmCover.hidden = true;
        confirmCoverFallback.hidden = false;
        confirmCoverFallback.textContent = (b.title || '?').slice(0, 40);
      }
      confirmTitle.textContent = b.title || 'Unknown';
      confirmAuthor.textContent = 'by ' + ((b.authors || []).join(', ') || 'Unknown author');
      // Meta line: rating · binding · ISBN, separated by middots, omitting blanks
      const metaParts = [];
      if (payload.rating && payload.rating.avg) {
        metaParts.push('⭐ ' + payload.rating.avg.toFixed(2));
      }
      if (b.edition) metaParts.push('📕 ' + b.edition);
      if (b.isbn13) metaParts.push('ISBN ' + b.isbn13);
      confirmMeta.textContent = metaParts.join('  ·  ');
      confirmMeta.hidden = metaParts.length === 0;

      if (payload.trophy) {
        confirmTrophy.textContent =
          '🏆 Trophy match — requested by ' + payload.trophy.requestedBy +
          (payload.trophy.reason ? ' (' + payload.trophy.reason + ')' : '');
        confirmTrophy.hidden = false;
        // Already on trophy list — hide the "+ Trophy" shortcut.
        btnConfirmTrophy.hidden = true;
      } else {
        confirmTrophy.hidden = true;
        btnConfirmTrophy.hidden = false;
      }
      const existing = payload.existingCopies || [];
      if (existing.length > 0) {
        const summary = existing.map(function(c) {
          return c.edition || 'edition?';
        }).join(', ');
        confirmDup.textContent = '⚠️ Already owned (' + summary + ')';
        confirmDup.hidden = false;
        btnConfirmAdd.textContent = '📚 Add another copy anyway';
      } else {
        confirmDup.hidden = true;
        btnConfirmAdd.textContent = '📚 Add to library';
      }
      btnConfirmShare.hidden = !payload.shareEnabled;

      // Reset and pre-fill the edit form. Auto-open + warning when authors
      // came back empty — that's the most common scan-data hole.
      editTitleEl.value = b.title || '';
      editAuthorsEl.value = (b.authors || []).join(', ');
      editPublisherEl.value = b.publisher || '';
      editEditionEl.value = b.edition || '';
      const authorMissing = !b.authors || b.authors.length === 0;
      confirmEdit.open = authorMissing;
      editAuthorWarning.hidden = !authorMissing;

      confirmCard.hidden = false;
      overlayStatus.textContent = 'Confirm to add, or skip.';
    }

    function hideConfirm() {
      confirmCard.hidden = true;
      pendingConfirm = null;
      overlayStatus.textContent = 'Scanning…';
    }

    // ---- Fallback card (ISBN miss → title search) -------------------------
    const fallbackCard = document.getElementById('fallback-card');
    const fallbackIsbnEl = document.getElementById('fallback-isbn');
    const fallbackForm = document.getElementById('fallback-form');
    const fallbackTitleEl = document.getElementById('fallback-title');
    const fallbackAuthorEl = document.getElementById('fallback-author');
    const fallbackManualLink = document.getElementById('fallback-manual-link');
    const btnFallbackSkip = document.getElementById('btn-fallback-skip');
    let lastFailedIsbn = null;

    function showFallback(isbn) {
      lastFailedIsbn = isbn || null;
      fallbackTitleEl.value = '';
      fallbackAuthorEl.value = '';
      fallbackIsbnEl.textContent = isbn ? 'ISBN ' + isbn + ' wasn\u2019t found.' : '';
      // "Add manually" deep-links to /books/new with whatever the user has
      // typed plus the failed ISBN, so they don't have to retype anything.
      function syncManualLink() {
        const params = new URLSearchParams();
        if (lastFailedIsbn) params.set('isbn', lastFailedIsbn);
        if (fallbackTitleEl.value.trim()) params.set('title', fallbackTitleEl.value.trim());
        if (fallbackAuthorEl.value.trim()) params.set('authors', fallbackAuthorEl.value.trim());
        fallbackManualLink.href = '/books/new' + (params.toString() ? '?' + params.toString() : '');
      }
      fallbackTitleEl.oninput = syncManualLink;
      fallbackAuthorEl.oninput = syncManualLink;
      syncManualLink();
      fallbackCard.hidden = false;
      // Defer focus so iOS Safari doesn't drop the soft keyboard immediately.
      setTimeout(function() { fallbackTitleEl.focus(); }, 50);
      overlayStatus.textContent = 'Search by title or add manually.';
    }

    function hideFallback() {
      fallbackCard.hidden = true;
      lastFailedIsbn = null;
      overlayStatus.textContent = 'Scanning…';
    }

    fallbackForm.addEventListener('submit', function(e) {
      e.preventDefault();
      const title = fallbackTitleEl.value.trim();
      const author = fallbackAuthorEl.value.trim();
      if (!title) return;
      hideFallback();
      // Reset the ISBN debouncer so a follow-up scan of the same barcode
      // still works after the user takes the title path.
      lastSubmitted = null;
      previewLookup({ title: title, author: author || undefined });
    });
    btnFallbackSkip.addEventListener('click', function() {
      hideFallback();
      lastSubmitted = null;
    });

    btnConfirmAdd.addEventListener('click', async function() {
      if (!pendingConfirm) return;
      const req = Object.assign({}, pendingConfirm.request);
      const original = pendingConfirm.payload.book || {};

      // Collect any user edits and pass them as override* fields on /scan.
      // Anything left at the original value is omitted to keep payloads clean.
      const newTitle = editTitleEl.value.trim();
      const newAuthorsRaw = editAuthorsEl.value.trim();
      const newPublisher = editPublisherEl.value.trim();
      const newEdition = editEditionEl.value.trim();
      if (newTitle && newTitle !== (original.title || '')) {
        req.overrideTitle = newTitle;
      }
      const origAuthorsStr = (original.authors || []).join(', ');
      if (newAuthorsRaw !== origAuthorsStr) {
        req.overrideAuthors = newAuthorsRaw;
      }
      if (newPublisher && newPublisher !== (original.publisher || '')) {
        req.overridePublisher = newPublisher;
      }
      if (newEdition !== (original.edition || '')) {
        req.overrideEdition = newEdition;
      }

      // Refuse to commit while the author field is still empty — protects
      // against the easy mistake of confirming a metadata-incomplete book.
      const effectiveAuthors = req.overrideAuthors !== undefined
        ? req.overrideAuthors.trim()
        : origAuthorsStr;
      if (!effectiveAuthors) {
        confirmEdit.open = true;
        editAuthorsEl.focus();
        editAuthorWarning.textContent = '⚠️ Please add at least one author before adding.';
        editAuthorWarning.hidden = false;
        return;
      }

      if (pendingConfirm.payload.shareEnabled) req.share = true;
      hideConfirm();
      await submitLookup(req);
    });
    btnConfirmSkip.addEventListener('click', function() {
      // Reset debouncer so the same barcode can be re-scanned intentionally.
      lastSubmitted = null;
      // Stash the skipped book locally so the user can revisit it later
      // from the "Recently skipped" strip on /scan. Useful pattern: walk
      // away from a book in a store, then weeks later remember it.
      if (pendingConfirm && pendingConfirm.payload && pendingConfirm.payload.book) {
        const b = pendingConfirm.payload.book;
        const isbn = (pendingConfirm.request && pendingConfirm.request.isbn) || b.isbn13;
        if (isbn) {
          rememberSavedScan({
            isbn: isbn,
            title: b.title || 'Unknown',
            authors: (b.authors || []).join(', '),
            thumbnailUrl: b.thumbnailUrl || null,
            at: Date.now(),
          });
          renderSavedScans();
        }
      }
      hideConfirm();
    });

    btnConfirmShare.addEventListener('click', async function() {
      if (!pendingConfirm) return;
      const req = pendingConfirm.request;
      hideConfirm();
      setStatus('Sharing to Discord…');
      try {
        const res = await fetch('/scan/share', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(req),
        });
        const json = await res.json().catch(function() { return { ok: false, error: 'Bad response' }; });
        if (res.ok && json.ok) {
          showToast('👀 Shared to Discord', true);
          setStatus('Shared.');
        } else {
          showToast(json.error || 'Share failed', false);
        }
      } catch (err) {
        showToast('Network error', false);
      }
    });

    btnConfirmTrophy.addEventListener('click', async function() {
      if (!pendingConfirm) return;
      const req = pendingConfirm.request;
      const isbn = req.isbn || (pendingConfirm.payload.book && pendingConfirm.payload.book.isbn13);
      const titleStr = (pendingConfirm.payload.book && pendingConfirm.payload.book.title) || '';
      // Quick optional reason capture — "for Sam's birthday", "anniversary
      // trip", etc. Cancel still adds the trophy with no reason. Empty
      // string is treated as no reason.
      const reason = window.prompt('Add a reason? (optional — cancel to add without one)', '');
      hideConfirm();
      setStatus('Adding to trophy list…');
      if (reason && reason.trim()) {
        req.reason = reason.trim();
      }
      try {
        const res = await fetch('/scan/trophy', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(req),
        });
        const json = await res.json().catch(function() { return { ok: false, error: 'Bad response' }; });
        if (res.ok && json.ok) {
          if (json.alreadyExists) {
            showToast('🏆 Already on trophy list', true);
          } else {
            showToast('🏆 Added to trophy list' + (req.reason ? ' — ' + req.reason : ''), true);
            // Update local cache so the next scan of the same book is
            // flagged instantly without waiting on a server round-trip.
            if (isbn && lookupCache && !lookupCache.trophy.includes(isbn)) {
              lookupCache.trophy.push(isbn);
              persistLookupCache();
            }
            // Remove from saved-scans if it was there.
            removeSavedScan(isbn);
            renderSavedScans();
          }
          setStatus('Added to trophy list.');
        } else {
          showToast(json.error || 'Trophy add failed', false);
        }
      } catch (err) {
        showToast('Network error', false);
      }
      void titleStr; // reserved for future toast detail
    });

    async function previewLookup(payload) {
      if (busy) return;
      busy = true;
      overlayStatus.textContent = 'Looking up…';

      // Race: server lookup (authoritative — has trophy + dedupe + cached
      // rating + binding) vs Open Library straight from the browser (often
      // faster on the first scan of a new ISBN). Whichever returns first
      // paints the card; the server response always wins on the fields it
      // owns (trophy / existingCopies / shareEnabled).
      let painted = false;
      let serverData = null;
      let clientData = null;

      function paint() {
        if (!serverData && !clientData) return;
        // Merge: server fields win for trophy/dedupe/edition/rating; client
        // fills in title/authors/cover/rating when server hasn't responded yet.
        const merged = {
          ok: true,
          shareEnabled: serverData ? serverData.shareEnabled : false,
          book: Object.assign({}, clientData ? clientData.book : null, serverData ? serverData.book : null),
          rating: (serverData && serverData.rating) || (clientData && clientData.rating) || null,
          trophy: serverData ? serverData.trophy : null,
          existingCopies: serverData ? serverData.existingCopies : [],
        };
        if (!merged.book || !merged.book.title) return;
        if (!painted) {
          showConfirm(merged, payload);
          painted = true;
        } else {
          // Refresh in place (covers the case where server arrives after
          // client and adds trophy/dedupe info we didn't have).
          showConfirm(merged, payload);
        }
      }

      // Reuse a speculative lookup started during the two-frame wait, when
      // available. Otherwise issue a fresh fetch as before.
      const speculative = payload.isbn ? consumeSpeculativeForIsbn(payload.isbn) : null;
      const serverFetch = speculative
        || fetch('/scan/lookup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        }).then(function(res) {
          return res.json().then(function(j) { return { ok: res.ok, status: res.status, json: j }; });
        });

      const serverP = serverFetch
        .then(function(r) {
          if (!r) return;
          if (r.ok && r.json && r.json.ok) {
            serverData = r.json;
            paint();
          } else if (!painted) {
            // Server failure with no client data either. Recovery paths:
            //   • ISBN 404 → in-overlay fallback card (try by title)
            //   • Title 404 (already tried both) → /books/new with prefill
            //   • Other errors (auth, network) → toast and resume scanning
            if (r.status === 404 && payload.isbn) {
              showFallback(payload.isbn);
            } else if (r.status === 404 && payload.title) {
              const params = new URLSearchParams();
              if (lastFailedIsbn) params.set('isbn', lastFailedIsbn);
              if (payload.title) params.set('title', payload.title);
              if (payload.author) params.set('authors', payload.author);
              window.location.href = '/books/new?' + params.toString();
            } else {
              showToast((r.json && r.json.error) || 'Not found', false);
              overlayStatus.textContent = 'Scanning…';
            }
            lastSubmitted = null;
          }
        })
        .catch(function() {
          if (!painted) {
            showToast('Network error', false);
            lastSubmitted = null;
          }
        });

      const clientP = payload.isbn
        ? clientLookupOpenLibrary(payload.isbn)
            .then(function(r) {
              if (r) {
                clientData = r;
                paint();
              }
            })
            .catch(function() { /* swallow */ })
        : Promise.resolve();

      try {
        await Promise.allSettled([serverP, clientP]);
      } finally {
        busy = false;
      }
    }

    /**
     * Browser-side Open Library lookup. Two CORS-friendly fetches:
     *   1. /search.json?isbn=  — title, authors, cover (1 call)
     *   2. /works/<id>/ratings.json — average + count
     * Returns the same shape the server's /scan/lookup returns so paint() can
     * merge them with no special-casing.
     */
    async function clientLookupOpenLibrary(isbn) {
      try {
        const res = await fetch(
          'https://openlibrary.org/search.json?isbn=' + encodeURIComponent(isbn) + '&limit=1'
        );
        if (!res.ok) return null;
        const json = await res.json();
        const doc = json.docs && json.docs[0];
        if (!doc) return null;

        const out = {
          ok: true,
          book: {
            title: doc.title || 'Unknown',
            authors: doc.author_name || [],
            isbn13: isbn,
            thumbnailUrl: doc.cover_i
              ? 'https://covers.openlibrary.org/b/id/' + doc.cover_i + '-M.jpg'
              : null,
            source: 'open_library',
            edition: null,
          },
          rating: null,
        };

        const workKey = (doc.key || '').replace(/^\/works\//, '');
        if (workKey) {
          try {
            const r = await fetch('https://openlibrary.org/works/' + workKey + '/ratings.json');
            if (r.ok) {
              const j = await r.json();
              if (j.summary && j.summary.average && j.summary.count > 0) {
                out.rating = { avg: j.summary.average, count: j.summary.count };
              }
            }
          } catch (e) { /* rating optional */ }
        }
        return out;
      } catch (err) {
        return null;
      }
    }

    function renderResult(payload, ok) {
      const div = document.createElement('div');
      div.className = ok ? 'scan-result' : 'scan-result error';
      if (ok) {
        const b = payload.book;
        const trophy = payload.trophyAcquired ? '<span class="trophy">🏆 Trophy match!</span>' : '';
        div.innerHTML =
          (b.thumbnailUrl ? '<img src="' + b.thumbnailUrl + '" alt="">' : '') +
          '<div class="scan-result-body"><strong>' + escapeHtml(b.title) + '</strong>' +
          '<div class="hint">' + escapeHtml((b.authors || []).join(', ') || 'Unknown author') + '</div>' +
          (b.isbn13 ? '<div class="hint">ISBN ' + escapeHtml(b.isbn13) + '</div>' : '') +
          trophy +
          (payload.copyId ? renderCopyEditor(payload.copyId, payload.suggestedEdition || null) : '') +
          '</div>';
        if (payload.copyId) wireCopyEditor(div, payload.copyId);
      } else {
        div.textContent = payload.error || 'Scan failed';
      }
      results.prepend(div);
      while (results.children.length > 8) results.removeChild(results.lastChild);
    }

    function renderCopyEditor(copyId, suggestedEdition) {
      const conditionOpts = ['', 'new', 'like-new', 'good', 'fair', 'poor']
        .map(function(v) { return '<option value="' + v + '">' + (v || '— condition') + '</option>'; })
        .join('');
      const editionOpts = ['', 'hardcover', 'paperback', 'mass-market', 'special', 'signed', 'boxset', 'other']
        .map(function(v) {
          const sel = (v === suggestedEdition) ? ' selected' : '';
          return '<option value="' + v + '"' + sel + '>' + (v || '— edition') + '</option>';
        })
        .join('');
      return (
        '<form class="copy-editor" data-copy="' + copyId + '">' +
          '<select name="condition">' + conditionOpts + '</select>' +
          '<select name="edition">' + editionOpts + '</select>' +
          '<button type="submit">Save details</button>' +
          '<a href="/library/copy/' + copyId + '" class="hint">edit more →</a>' +
          '<span class="copy-editor-status hint"></span>' +
        '</form>'
      );
    }

    function wireCopyEditor(container, copyId) {
      const form = container.querySelector('form.copy-editor');
      if (!form) return;
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        const status = form.querySelector('.copy-editor-status');
        status.textContent = 'Saving…';
        const fd = new FormData(form);
        const body = new URLSearchParams();
        fd.forEach(function(v, k) { body.append(k, v); });
        try {
          const res = await fetch('/library/copy/' + copyId + '/edit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
            body: body.toString(),
          });
          if (res.ok) {
            status.textContent = '✓ saved';
            form.querySelector('button').disabled = true;
          } else {
            status.textContent = 'Save failed';
          }
        } catch (err) {
          status.textContent = 'Network error';
        }
      });
    }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, function(c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
      });
    }

    async function submitLookup(payload, opts) {
      opts = opts || {};
      // The bulk auto-commit path is fired from inside showConfirm, which
      // is itself called from inside previewLookup's still-pending paint()
      // — so `busy` is still true at that moment. Bulk callers pass
      // bypassBusy:true so the actual /scan POST runs instead of silently
      // no-opping. The single-shot guard remains via pendingConfirm /
      // onDecoded, so this stays safe from duplicate decodes.
      if (busy && !opts.bypassBusy) return;
      busy = true;
      const desc = payload.isbn || payload.title || '';
      setStatus('Looking up ' + desc + '…');
      setPill('searching', 'looking up ' + (desc || 'book') + '…');
      try {
        const res = await fetch('/scan', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const json = await res.json().catch(function() { return { ok: false, error: 'Bad response' }; });
        renderResult(json, res.ok && json.ok);
        if (res.ok && json.ok) {
          setStatus('Added: ' + json.book.title);
          const verb = json.trophyAcquired ? '🏆 ' : '✓ ';
          showToast(verb + (json.trophyAcquired ? '' : 'Added: ') + json.book.title, true);
          setPill(json.trophyAcquired ? 'trophy' : 'ok', verb + json.book.title);
          // Push the filmstrip tile now that we have json.copyId.
          if (opts.bulkTile) {
            pushBulkTile(
              opts.tileBook || json.book,
              json.trophyAcquired ? 'trophy' : (opts.tileKind || 'new'),
              json.copyId || null
            );
          }
          const newIsbn = (json.book && json.book.isbn13) || payload.isbn;
          if (newIsbn && lookupCache && lookupCache.owned.indexOf(newIsbn) === -1) {
            lookupCache.owned.push(newIsbn);
            persistLookupCache();
          }
        } else {
          setStatus(json.error || 'Failed');
          showToast(json.error || 'Failed', false);
          setPill('err', json.error || 'lookup failed');
        }
      } catch (err) {
        renderResult({ error: String(err) }, false);
        setStatus('Network error');
        showToast('Network error', false);
      } finally {
        busy = false;
      }
    }

    async function submitIsbn(isbn) {
      return submitLookup({ isbn: isbn });
    }

    function onDecoded(text) {
      // Skip new decodes while a confirm card is up.
      if (pendingConfirm) return;
      // Don't decode while a network commit is in flight — bulk mode would
      // otherwise queue duplicates faster than the server can finish.
      if (busy) return;

      // Spine-sticker fast-path: when we see a QR that points at one of
      // our own /library/copy/<id> URLs (printed via /library/labels),
      // navigate straight to the copy detail page. No ISBN flow at all.
      const copyMatch = text.match(/\/library\/copy\/([A-Za-z0-9_-]{6,40})(?:[?#].*)?$/);
      if (copyMatch) {
        flashReticle('lock');
        if (navigator.vibrate) navigator.vibrate(40);
        window.location.href = '/library/copy/' + copyMatch[1];
        return;
      }

      const now = Date.now();
      if (text === lastSubmitted && now - lastSubmittedAt < 4000) return;
      const cleaned = text.replace(/[^0-9Xx]/g, '');
      if (cleaned.length !== 10 && cleaned.length !== 13) {
        return;
      }

      // Bulk mode: skip the two-frame confirmation gate. The user has
      // explicitly opted into rapid-fire scanning. lastSubmitted still
      // throttles repeats of the same barcode within 4s, so a held-still
      // book doesn't get added twice. Saves ~600ms per scan.
      if (bulkMode) {
        lastSubmitted = cleaned;
        lastSubmittedAt = now;
        pendingDecode = null;
        flashReticle('lock');
        if (navigator.vibrate) navigator.vibrate(40);
        flashCachedStatus(cleaned);
        previewLookup({ isbn: cleaned });
        return;
      }

      // Two-frame confirmation: require the same decode twice within the
      // window before committing. Filters single-frame misreads.
      if (pendingDecode === cleaned && now - pendingDecodeAt < CONFIRM_WINDOW_MS) {
        lastSubmitted = cleaned;
        lastSubmittedAt = now;
        pendingDecode = null;
        flashReticle('lock');
        if (navigator.vibrate) navigator.vibrate(40);
        flashCachedStatus(cleaned);
        previewLookup({ isbn: cleaned });
      } else {
        pendingDecode = cleaned;
        pendingDecodeAt = now;
        flashReticle('detect');
        // Speculative lookup: kick off the network call NOW so it overlaps
        // the CONFIRM_WINDOW_MS wait. previewLookup is a no-op when busy
        // is already set, so we record the in-flight ISBN and let the
        // confirm path attach to its result.
        startSpeculativeLookup(cleaned);
      }
    }

    // ---- Speculative lookup -----------------------------------------------
    // When the first decoded frame lands, we already have a high-confidence
    // ISBN. Kick off /scan/lookup in the background so by the time the
    // two-frame gate is satisfied, we either already have the answer or
    // we're moments away. Saves ~300-1000ms of perceived latency.
    let speculativeIsbn = null;
    let speculativePromise = null;

    function startSpeculativeLookup(isbn) {
      if (speculativeIsbn === isbn && speculativePromise) return;
      speculativeIsbn = isbn;
      speculativePromise = fetch('/scan/lookup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ isbn: isbn }),
      })
        .then(function(res) { return res.json().then(function(j) { return { ok: res.ok, status: res.status, json: j }; }); })
        .catch(function() { return null; });
    }

    function consumeSpeculativeForIsbn(isbn) {
      if (speculativeIsbn === isbn && speculativePromise) {
        const p = speculativePromise;
        speculativeIsbn = null;
        speculativePromise = null;
        return p;
      }
      return null;
    }

    // ---- Offline lookup cache ---------------------------------------------
    // Mirror of the library's owned + trophy ISBNs so the camera UI can
    // answer "do I already own this?" instantly, even on flaky cellular.
    // Refreshed on every scan-page load; falls back to localStorage when
    // the network is slow.
    const LOOKUP_CACHE_KEY = 'ph_lookup_cache_v1';
    let lookupCache = null;
    try {
      const raw = localStorage.getItem(LOOKUP_CACHE_KEY);
      if (raw) {
        const parsed = JSON.parse(raw);
        if (parsed && Array.isArray(parsed.owned) && Array.isArray(parsed.trophy)) {
          lookupCache = parsed;
        }
      }
    } catch (err) { /* localStorage unavailable, fine */ }

    function persistLookupCache() {
      if (!lookupCache) return;
      try { localStorage.setItem(LOOKUP_CACHE_KEY, JSON.stringify(lookupCache)); }
      catch (err) { /* full or disabled, ignore */ }
    }

    fetch('/scan/cache.json', { credentials: 'same-origin' })
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(c) {
        if (c && Array.isArray(c.owned) && Array.isArray(c.trophy)) {
          lookupCache = { owned: c.owned, trophy: c.trophy };
          persistLookupCache();
        }
      })
      .catch(function() { /* offline; whatever's in localStorage stands */ });

    function flashCachedStatus(isbn) {
      if (!lookupCache || !isbn) return;
      if (lookupCache.owned.indexOf(isbn) !== -1) {
        showToast('✓ Already in your library', true);
      } else if (lookupCache.trophy.indexOf(isbn) !== -1) {
        showToast('🏆 On your trophy list', true);
      }
    }

    // ---- Saved-skipped-scans (revisit later) ------------------------------
    // Stored in localStorage. Each entry is the smallest book preview we
    // had at the moment of Skip, capped at 20 most-recent. UI renders as
    // a horizontal strip above the manual-lookup form so the user can
    // re-add or forget without retyping the ISBN.
    const SAVED_SCANS_KEY = 'ph_saved_scans_v1';
    const SAVED_SCANS_MAX = 20;
    function readSavedScans() {
      try {
        const raw = localStorage.getItem(SAVED_SCANS_KEY);
        if (!raw) return [];
        const parsed = JSON.parse(raw);
        return Array.isArray(parsed) ? parsed : [];
      } catch { return []; }
    }
    function writeSavedScans(list) {
      try { localStorage.setItem(SAVED_SCANS_KEY, JSON.stringify(list.slice(0, SAVED_SCANS_MAX))); }
      catch { /* full or disabled, ignore */ }
    }
    function rememberSavedScan(entry) {
      const list = readSavedScans().filter(function(e) { return e.isbn !== entry.isbn; });
      list.unshift(entry);
      writeSavedScans(list);
    }
    function removeSavedScan(isbn) {
      writeSavedScans(readSavedScans().filter(function(e) { return e.isbn !== isbn; }));
    }
    function renderSavedScans() {
      const host = document.getElementById('saved-scans');
      if (!host) return;
      const list = readSavedScans();
      if (list.length === 0) { host.hidden = true; host.innerHTML = ''; return; }
      host.hidden = false;
      host.innerHTML = '<h3 class="hint" style="margin:.25rem 0">Recently skipped</h3>';
      const ul = document.createElement('ul');
      ul.className = 'saved-scans-list';
      list.forEach(function(e) {
        const li = document.createElement('li');
        li.className = 'saved-scan-chip';
        const cover = e.thumbnailUrl
          ? '<img src="' + e.thumbnailUrl + '" alt="" loading="lazy" />'
          : '<div class="saved-scan-fallback">📕</div>';
        const safeTitle = (e.title || '').replace(/[<>&"]/g, function(c) {
          return { '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;' }[c];
        });
        li.innerHTML = cover +
          '<div class="saved-scan-meta">' +
            '<strong>' + safeTitle + '</strong>' +
            (e.authors ? '<span class="hint">' + e.authors + '</span>' : '') +
          '</div>' +
          '<div class="saved-scan-actions">' +
            '<button type="button" data-act="add" data-isbn="' + e.isbn + '">+ Library</button>' +
            '<button type="button" data-act="trophy" data-isbn="' + e.isbn + '">🏆</button>' +
            '<button type="button" data-act="forget" data-isbn="' + e.isbn + '" class="link-skip">forget</button>' +
          '</div>';
        ul.appendChild(li);
      });
      host.appendChild(ul);
      ul.addEventListener('click', async function(ev) {
        const btn = ev.target.closest('button[data-act]');
        if (!btn) return;
        const isbn = btn.getAttribute('data-isbn');
        const act = btn.getAttribute('data-act');
        if (act === 'forget') {
          removeSavedScan(isbn);
          renderSavedScans();
          return;
        }
        const url = act === 'trophy' ? '/scan/trophy' : '/scan';
        btn.disabled = true;
        try {
          const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ isbn: isbn }),
          });
          const json = await res.json().catch(function() { return { ok: false }; });
          if (res.ok && json.ok) {
            removeSavedScan(isbn);
            renderSavedScans();
            showToast(act === 'trophy' ? '🏆 Added to trophy' : '✓ Added to library', true);
          } else {
            showToast((json && json.error) || 'Failed', false);
            btn.disabled = false;
          }
        } catch {
          showToast('Network error', false);
          btn.disabled = false;
        }
      });
    }
    renderSavedScans();

    async function tryAcquireWakeLock() {
      if (!('wakeLock' in navigator)) return;
      try {
        wakeLock = await navigator.wakeLock.request('screen');
      } catch {
        /* permission denied or not supported */
      }
    }

    function releaseWakeLock() {
      if (wakeLock) {
        wakeLock.release().catch(() => undefined);
        wakeLock = null;
      }
    }

    function maybeShowTorch() {
      if (!mediaStream) return;
      const track = mediaStream.getVideoTracks()[0];
      if (!track) return;
      const caps = track.getCapabilities ? track.getCapabilities() : {};
      if (caps && 'torch' in caps) {
        btnTorch.hidden = false;
      }
    }

    btnTorch.addEventListener('click', async function() {
      if (!mediaStream) return;
      const track = mediaStream.getVideoTracks()[0];
      if (!track) return;
      const on = btnTorch.getAttribute('aria-pressed') !== 'true';
      try {
        await track.applyConstraints({ advanced: [{ torch: on }] });
        btnTorch.setAttribute('aria-pressed', String(on));
        btnTorch.classList.toggle('active', on);
      } catch (err) {
        showToast('Torch unavailable', false);
      }
    });

    async function startCamera() {
      if (!hasZxing) return;
      // Show overlay first so the video element is laid out before play().
      overlay.hidden = false;
      document.body.classList.add('camera-open');
      overlayStatus.textContent = 'Requesting camera…';
      try {
        // Restrict ZXing to ISBN-bearing formats. Faster + dramatically
        // fewer misreads vs the all-formats default. ISBNs are EAN-13;
        // a few older ones are EAN-8 / UPC-A.
        const hints = new Map();
        try {
          // BarcodeFormat enum values (from @zxing/library):
          //   QR_CODE = 11, EAN_8 = 6, EAN_13 = 7, UPC_A = 14
          // Adding QR_CODE so spine stickers (printed via /library/labels)
          // jump straight to the copy detail page when scanned.
          hints.set(2 /* DecodeHintType.POSSIBLE_FORMATS */, [7, 6, 14, 11]);
          hints.set(3 /* DecodeHintType.TRY_HARDER */, true);
        } catch {}
        reader = new ZXingBrowser.BrowserMultiFormatReader(hints);

        // Pick the back camera. Cached in sessionStorage to skip the
        // 50-200ms enumerateDevices() call on subsequent starts.
        let deviceId = null;
        try {
          const cachedRaw = sessionStorage.getItem('ph_back_camera_id');
          if (cachedRaw) deviceId = cachedRaw;
        } catch {}
        if (!deviceId) {
          const devices = await ZXingBrowser.BrowserCodeReader.listVideoInputDevices();
          const back = devices.find(function(d) { return /back|rear|environment/i.test(d.label); });
          deviceId = back ? back.deviceId : (devices[0] && devices[0].deviceId);
          if (deviceId) {
            try { sessionStorage.setItem('ph_back_camera_id', deviceId); } catch {}
          }
        }
        // 720p instead of 1080p — barcodes decode several Hz faster on
        // mobile because each frame ZXing inspects is ~half the pixels,
        // with no measurable hit to EAN-13 recognition (the bars are
        // big enough to read at 720p easily).
        const constraints = {
          video: Object.assign(
            {
              facingMode: { ideal: 'environment' },
              width: { ideal: 1280 },
              height: { ideal: 720 },
            },
            deviceId ? { deviceId: { exact: deviceId } } : {}
          ),
        };
        controls = await reader.decodeFromConstraints(constraints, video, function(result) {
          if (result) onDecoded(result.getText());
        });
        mediaStream = video.srcObject;
        maybeShowTorch();
        tryAcquireWakeLock();
        overlayStatus.textContent = 'Scanning…';
        setStatus('Camera open. Tap Done to close.');
        setPill('idle', 'pointing…');
      } catch (err) {
        console.error(err);
        overlay.hidden = true;
        document.body.classList.remove('camera-open');
        httpsWarning.hidden = false;
        setStatus('Camera blocked: ' + (err && err.message ? err.message : err));
      }
    }

    function stopCamera() {
      if (controls) controls.stop();
      controls = null;
      mediaStream = null;
      btnTorch.hidden = true;
      btnTorch.setAttribute('aria-pressed', 'false');
      btnTorch.classList.remove('active');
      releaseWakeLock();
      overlay.hidden = true;
      document.body.classList.remove('camera-open');
      overlayToast.hidden = true;
      hideConfirm();
      hideFallback();
      // Discard any in-flight speculative lookup so the next session
      // starts clean.
      speculativeIsbn = null;
      speculativePromise = null;
      setStatus('');
    }

    btnStart.addEventListener('click', startCamera);
    btnDone.addEventListener('click', stopCamera);

    // Esc closes the overlay for keyboard users.
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !overlay.hidden) stopCamera();
    });

    document.getElementById('photo-input').addEventListener('change', async function(e) {
      const file = e.target.files && e.target.files[0];
      if (!file) return;
      e.target.value = '';
      if (!hasZxing) {
        setStatus('Barcode library failed to load.');
        return;
      }
      setStatus('Scanning photo…');
      try {
        const url = URL.createObjectURL(file);
        const tmp = new ZXingBrowser.BrowserMultiFormatReader();
        const result = await tmp.decodeFromImageUrl(url).catch(function() { return null; });
        URL.revokeObjectURL(url);
        if (!result) {
          setStatus('No barcode found in that photo.');
          return;
        }
        const cleaned = result.getText().replace(/[^0-9Xx]/g, '');
        if (cleaned.length !== 10 && cleaned.length !== 13) {
          setStatus('Found a barcode but it was not an ISBN: ' + result.getText());
          return;
        }
        setStatus('ISBN ' + cleaned + ' — looking up…');
        // Browse photos goes straight through (no fullscreen overlay needed)
        // and uses the same submitLookup -> /scan flow as the manual form.
        await submitLookup({ isbn: cleaned });
      } catch (err) {
        setStatus('Failed to read photo: ' + (err && err.message ? err.message : err));
      }
    });

    manualForm.addEventListener('submit', function(e) {
      e.preventDefault();
      const isbn = document.getElementById('manual-isbn').value.trim();
      const title = document.getElementById('manual-title').value.trim();
      const author = document.getElementById('manual-author').value.trim();
      if (!isbn && !title) {
        setStatus('Enter an ISBN or a title.');
        return;
      }
      const payload = isbn ? { isbn: isbn } : { title: title, author: author || undefined };
      submitLookup(payload);
      document.getElementById('manual-isbn').value = '';
      document.getElementById('manual-title').value = '';
      document.getElementById('manual-author').value = '';
      document.getElementById('manual-isbn').focus();
    });

    // Auto-trigger lookup when invoked with ?isbn=XXX in the URL — used by
    // iOS Shortcuts that scan a barcode and open Paper Hoard with the value
    // pre-populated. Strips the param after firing so a refresh doesn't
    // re-submit the same lookup.
    (function autoTriggerFromUrl() {
      try {
        const url = new URL(window.location.href);
        const isbn = (url.searchParams.get('isbn') || '').replace(/[^0-9Xx]/g, '');
        if (isbn.length === 10 || isbn.length === 13) {
          url.searchParams.delete('isbn');
          window.history.replaceState({}, '', url.toString());
          setStatus('ISBN ' + isbn + ' — looking up…');
          flashCachedStatus(isbn);
          previewLookup({ isbn: isbn });
        }
      } catch (err) { /* old browser, skip */ }
    })();
  })();
</script>

