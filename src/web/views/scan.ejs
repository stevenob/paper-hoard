<% const pageTitle = 'Scan' %>
<%- include('_header') %>

<h1>📷 Scan a book</h1>

<% if (!activeUser) { %>
  <p class="notice">You need to <a href="/auth/login">log in with Discord</a> before scanning books — every scan is recorded as added by the logged-in user.</p>
<% } %>
<% if (!library) { %>
  <p class="notice">No family library exists yet. In Discord, run <code>/library</code> once so Smaug creates the household library, then come back here.</p>
<% } %>

<div class="scanner-launch">
  <div class="scanner-launch-buttons">
    <button type="button" id="btn-start" class="big">📷 Start camera</button>
    <label class="button big" for="photo-input">🖼 Choose photo</label>
    <input type="file" id="photo-input" accept="image/*" capture="environment" hidden />
  </div>
  <span id="status" class="hint"></span>
  <p class="hint" id="https-warning" hidden>
    Your browser blocked camera access. Most browsers (especially iOS Safari) require an
    <strong>https://</strong> URL or <code>localhost</code> for camera permission.
    Use the manual lookup below as a fallback.
  </p>
</div>

<!-- Fullscreen camera overlay; hidden until Start camera is tapped. -->
<div id="camera-overlay" class="camera-overlay" hidden role="dialog" aria-modal="true" aria-label="Barcode scanner">
  <div class="camera-topbar">
    <span id="overlay-status">Scanning… point at the barcode on the back cover.</span>
    <button type="button" id="btn-done" class="primary">Done</button>
  </div>
  <video id="video" playsinline muted autoplay aria-label="Camera feed"></video>
  <div class="camera-toast" id="overlay-toast" hidden role="status" aria-live="polite"></div>
  <!-- Confirm card shown after a successful barcode decode + lookup. -->
  <div id="confirm-card" class="confirm-card" hidden role="dialog" aria-label="Confirm scanned book">
    <img id="confirm-cover" alt="" hidden />
    <h3 id="confirm-title">…</h3>
    <p class="hint" id="confirm-authors"></p>
    <p class="hint" id="confirm-isbn"></p>
    <p id="confirm-trophy" class="trophy" hidden></p>
    <div class="confirm-actions">
      <button type="button" id="btn-confirm-add" class="primary">Add to library</button>
      <button type="button" id="btn-confirm-skip" class="danger">Skip</button>
    </div>
  </div>
</div>

<h2>Or look up manually</h2>
<form id="manual-form" class="stacked">
  <label>ISBN <input id="manual-isbn" name="isbn" placeholder="9780593135204" autocomplete="off" inputmode="numeric" /></label>
  <p class="hint">— or —</p>
  <label>Title <input id="manual-title" name="title" placeholder="Project Hail Mary" autocomplete="off" /></label>
  <label>Author <input id="manual-author" name="author" placeholder="Andy Weir (optional, narrows the search)" autocomplete="off" /></label>
  <button type="submit">Look up</button>
</form>

<div id="results"></div>

<h2>Recent additions</h2>
<% if (recent.length === 0) { %>
  <p class="hint">Nothing yet — scan your first book above.</p>
<% } else { %>
  <ul class="recent-list">
    <% recent.forEach(function(c) { %>
      <li>
        <strong><%= c.book.title %></strong> — <%= c.book.authors.join(', ') %>
        <span class="hint">added by <%= c.addedBy.displayName %></span>
      </li>
    <% }) %>
  </ul>
<% } %>

<!-- ZXing barcode scanner: vendored UMD bundle, served from this app. -->
<script src="/static/zxing-browser.min.js"></script>
<script>
  (function() {
    const video = document.getElementById('video');
    const btnStart = document.getElementById('btn-start');
    const btnDone = document.getElementById('btn-done');
    const status = document.getElementById('status');
    const overlay = document.getElementById('camera-overlay');
    const overlayStatus = document.getElementById('overlay-status');
    const overlayToast = document.getElementById('overlay-toast');
    const confirmCard = document.getElementById('confirm-card');
    const confirmCover = document.getElementById('confirm-cover');
    const confirmTitle = document.getElementById('confirm-title');
    const confirmAuthors = document.getElementById('confirm-authors');
    const confirmIsbn = document.getElementById('confirm-isbn');
    const confirmTrophy = document.getElementById('confirm-trophy');
    const btnConfirmAdd = document.getElementById('btn-confirm-add');
    const btnConfirmSkip = document.getElementById('btn-confirm-skip');
    const httpsWarning = document.getElementById('https-warning');
    const results = document.getElementById('results');
    const manualForm = document.getElementById('manual-form');

    const hasZxing = typeof ZXingBrowser !== 'undefined';
    if (!hasZxing) {
      status.textContent = 'Barcode library failed to load — manual entry still works.';
      btnStart.disabled = true;
    }

    let reader = null;
    let controls = null;
    let lastSubmitted = null;
    let lastSubmittedAt = 0;
    let busy = false;
    let toastTimer = null;
    let pendingConfirm = null;

    function setStatus(msg) {
      status.textContent = msg || '';
      if (msg) overlayStatus.textContent = msg;
    }

    function showToast(text, ok) {
      overlayToast.textContent = text;
      overlayToast.className = 'camera-toast ' + (ok ? 'ok' : 'err');
      overlayToast.hidden = false;
      if (toastTimer) clearTimeout(toastTimer);
      toastTimer = setTimeout(function() { overlayToast.hidden = true; }, 2500);
    }

    function showConfirm(payload, originalRequest) {
      pendingConfirm = { payload: payload, request: originalRequest };
      const b = payload.book;
      if (b.thumbnailUrl) {
        confirmCover.src = b.thumbnailUrl;
        confirmCover.hidden = false;
      } else {
        confirmCover.hidden = true;
      }
      confirmTitle.textContent = b.title || 'Unknown';
      confirmAuthors.textContent = (b.authors || []).join(', ') || 'Unknown author';
      confirmIsbn.textContent = b.isbn13 ? 'ISBN ' + b.isbn13 : '';
      if (payload.trophy) {
        confirmTrophy.textContent =
          '🏆 Trophy match — requested by ' + payload.trophy.requestedBy +
          (payload.trophy.reason ? ' (' + payload.trophy.reason + ')' : '');
        confirmTrophy.hidden = false;
      } else {
        confirmTrophy.hidden = true;
      }
      confirmCard.hidden = false;
      overlayStatus.textContent = 'Confirm to add, or skip.';
    }

    function hideConfirm() {
      confirmCard.hidden = true;
      pendingConfirm = null;
      overlayStatus.textContent = 'Scanning…';
    }

    btnConfirmAdd.addEventListener('click', async function() {
      if (!pendingConfirm) return;
      const req = pendingConfirm.request;
      hideConfirm();
      // submitLookup hits POST /scan which mutates and returns full payload.
      await submitLookup(req);
    });
    btnConfirmSkip.addEventListener('click', function() {
      // Reset debouncer so the same barcode can be re-scanned intentionally.
      lastSubmitted = null;
      hideConfirm();
    });

    async function previewLookup(payload) {
      if (busy) return;
      busy = true;
      overlayStatus.textContent = 'Looking up…';
      try {
        const res = await fetch('/scan/lookup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const json = await res.json().catch(function() { return { ok: false, error: 'Bad response' }; });
        if (res.ok && json.ok) {
          showConfirm(json, payload);
        } else {
          showToast(json.error || 'Not found', false);
          overlayStatus.textContent = 'Scanning…';
          // Allow re-scan immediately on failure.
          lastSubmitted = null;
        }
      } catch (err) {
        showToast('Network error', false);
        lastSubmitted = null;
      } finally {
        busy = false;
      }
    }

    function renderResult(payload, ok) {
      const div = document.createElement('div');
      div.className = ok ? 'scan-result' : 'scan-result error';
      if (ok) {
        const b = payload.book;
        const trophy = payload.trophyAcquired ? '<span class="trophy">🏆 Trophy match!</span>' : '';
        div.innerHTML =
          (b.thumbnailUrl ? '<img src="' + b.thumbnailUrl + '" alt="">' : '') +
          '<div class="scan-result-body"><strong>' + escapeHtml(b.title) + '</strong>' +
          '<div class="hint">' + escapeHtml((b.authors || []).join(', ') || 'Unknown author') + '</div>' +
          (b.isbn13 ? '<div class="hint">ISBN ' + escapeHtml(b.isbn13) + '</div>' : '') +
          trophy +
          (payload.copyId ? renderCopyEditor(payload.copyId) : '') +
          '</div>';
        if (payload.copyId) wireCopyEditor(div, payload.copyId);
      } else {
        div.textContent = payload.error || 'Scan failed';
      }
      results.prepend(div);
      while (results.children.length > 8) results.removeChild(results.lastChild);
    }

    function renderCopyEditor(copyId) {
      const conditionOpts = ['', 'new', 'like-new', 'good', 'fair', 'poor']
        .map(function(v) { return '<option value="' + v + '">' + (v || '— condition') + '</option>'; })
        .join('');
      const editionOpts = ['', 'hardcover', 'paperback', 'mass-market', 'special', 'signed', 'boxset', 'other']
        .map(function(v) { return '<option value="' + v + '">' + (v || '— edition') + '</option>'; })
        .join('');
      return (
        '<form class="copy-editor" data-copy="' + copyId + '">' +
          '<select name="condition">' + conditionOpts + '</select>' +
          '<select name="edition">' + editionOpts + '</select>' +
          '<input name="location" placeholder="Location (optional)" />' +
          '<button type="submit">Save details</button>' +
          '<a href="/library/copy/' + copyId + '" class="hint">edit more →</a>' +
          '<span class="copy-editor-status hint"></span>' +
        '</form>'
      );
    }

    function wireCopyEditor(container, copyId) {
      const form = container.querySelector('form.copy-editor');
      if (!form) return;
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        const status = form.querySelector('.copy-editor-status');
        status.textContent = 'Saving…';
        const fd = new FormData(form);
        const body = new URLSearchParams();
        fd.forEach(function(v, k) { body.append(k, v); });
        try {
          const res = await fetch('/library/copy/' + copyId + '/edit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
            body: body.toString(),
          });
          if (res.ok) {
            status.textContent = '✓ saved';
            form.querySelector('button').disabled = true;
          } else {
            status.textContent = 'Save failed';
          }
        } catch (err) {
          status.textContent = 'Network error';
        }
      });
    }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, function(c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
      });
    }

    async function submitLookup(payload) {
      if (busy) return;
      busy = true;
      const desc = payload.isbn || payload.title || '';
      setStatus('Looking up ' + desc + '…');
      try {
        const res = await fetch('/scan', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const json = await res.json().catch(function() { return { ok: false, error: 'Bad response' }; });
        renderResult(json, res.ok && json.ok);
        if (res.ok && json.ok) {
          setStatus('Added: ' + json.book.title);
          showToast(
            (json.trophyAcquired ? '🏆 ' : '✓ Added: ') + json.book.title,
            true
          );
        } else {
          setStatus(json.error || 'Failed');
          showToast(json.error || 'Failed', false);
        }
      } catch (err) {
        renderResult({ error: String(err) }, false);
        setStatus('Network error');
        showToast('Network error', false);
      } finally {
        busy = false;
      }
    }

    async function submitIsbn(isbn) {
      return submitLookup({ isbn: isbn });
    }

    function onDecoded(text) {
      // Skip new decodes while a confirm card is up.
      if (pendingConfirm) return;
      const now = Date.now();
      if (text === lastSubmitted && now - lastSubmittedAt < 4000) return;
      lastSubmitted = text;
      lastSubmittedAt = now;
      const cleaned = text.replace(/[^0-9Xx]/g, '');
      if (cleaned.length !== 10 && cleaned.length !== 13) {
        setStatus('Ignored non-ISBN barcode: ' + text);
        return;
      }
      previewLookup({ isbn: cleaned });
    }

    async function startCamera() {
      if (!hasZxing) return;
      // Show overlay first so the video element is laid out before play().
      overlay.hidden = false;
      document.body.classList.add('camera-open');
      overlayStatus.textContent = 'Requesting camera…';
      try {
        reader = new ZXingBrowser.BrowserMultiFormatReader();
        const devices = await ZXingBrowser.BrowserCodeReader.listVideoInputDevices();
        const back = devices.find(function(d) { return /back|rear|environment/i.test(d.label); });
        const deviceId = back ? back.deviceId : (devices[0] && devices[0].deviceId);
        controls = await reader.decodeFromVideoDevice(deviceId, video, function(result) {
          if (result) onDecoded(result.getText());
        });
        overlayStatus.textContent = 'Scanning…';
        setStatus('Camera open. Tap Done to close.');
      } catch (err) {
        console.error(err);
        overlay.hidden = true;
        document.body.classList.remove('camera-open');
        httpsWarning.hidden = false;
        setStatus('Camera blocked: ' + (err && err.message ? err.message : err));
      }
    }

    function stopCamera() {
      if (controls) controls.stop();
      controls = null;
      overlay.hidden = true;
      document.body.classList.remove('camera-open');
      overlayToast.hidden = true;
      hideConfirm();
      setStatus('');
    }

    btnStart.addEventListener('click', startCamera);
    btnDone.addEventListener('click', stopCamera);

    // Esc closes the overlay for keyboard users.
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !overlay.hidden) stopCamera();
    });

    document.getElementById('photo-input').addEventListener('change', async function(e) {
      const file = e.target.files && e.target.files[0];
      if (!file) return;
      e.target.value = '';
      if (!hasZxing) {
        setStatus('Barcode library failed to load.');
        return;
      }
      setStatus('Scanning photo…');
      try {
        const url = URL.createObjectURL(file);
        const tmp = new ZXingBrowser.BrowserMultiFormatReader();
        const result = await tmp.decodeFromImageUrl(url).catch(function() { return null; });
        URL.revokeObjectURL(url);
        if (!result) {
          setStatus('No barcode found in that photo.');
          return;
        }
        const cleaned = result.getText().replace(/[^0-9Xx]/g, '');
        if (cleaned.length !== 10 && cleaned.length !== 13) {
          setStatus('Found a barcode but it was not an ISBN: ' + result.getText());
          return;
        }
        setStatus('ISBN ' + cleaned + ' — looking up…');
        // Browse photos goes straight through (no fullscreen overlay needed)
        // and uses the same submitLookup -> /scan flow as the manual form.
        await submitLookup({ isbn: cleaned });
      } catch (err) {
        setStatus('Failed to read photo: ' + (err && err.message ? err.message : err));
      }
    });

    manualForm.addEventListener('submit', function(e) {
      e.preventDefault();
      const isbn = document.getElementById('manual-isbn').value.trim();
      const title = document.getElementById('manual-title').value.trim();
      const author = document.getElementById('manual-author').value.trim();
      if (!isbn && !title) {
        setStatus('Enter an ISBN or a title.');
        return;
      }
      const payload = isbn ? { isbn: isbn } : { title: title, author: author || undefined };
      submitLookup(payload);
      document.getElementById('manual-isbn').value = '';
      document.getElementById('manual-title').value = '';
      document.getElementById('manual-author').value = '';
      document.getElementById('manual-isbn').focus();
    });
  })();
</script>

<%- include('_footer') %>
