<% const pageTitle = 'Household' %>
<%- include('_header') %>

<h1>Household members</h1>

<p class="hint">Members are automatically added the first time they log in with Discord.</p>

<% if (memberships.length === 0) { %>
  <p>No one has logged in yet.</p>
<% } else { %>
  <table class="data">
    <thead>
      <tr><th>Name</th><th>Discord ID</th><th>Library</th><th>Joined</th></tr>
    </thead>
    <tbody>
      <% memberships.forEach(function(m) { %>
        <tr>
          <td><%= m.user.displayName %><% if (activeUser && activeUser.id === m.user.id) { %> <span class="hint">(you)</span><% } %></td>
          <td><code><%= m.user.discordUserId %></code></td>
          <td><%= m.library.name %></td>
          <td><%= m.createdAt.toISOString().slice(0,10) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('_footer') %>
