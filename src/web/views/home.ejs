<% const pageTitle = 'Home' %>
<%- include('_header') %>

<h1>Welcome to Paper Hoard</h1>
<% if (!library) { %>
  <p class="notice">No family library is connected yet. Invite Smaug to your Discord server and run <code>/library</code> to create one — that's how Paper Hoard discovers your household guild.</p>
<% } else { %>
  <p>Connected to family library: <strong><%= library.name %></strong></p>
  <% if (!activeUser && oauthConfigured) { %>
    <p class="hint"><a href="/auth/login">Log in with Discord</a> to scan, log completions, or curate the trophy list.</p>
  <% } %>
<% } %>

<section class="cards">
  <a class="card" href="/library">
    <h2><%= physicalCount %></h2>
    <p>Physical books</p>
  </a>
  <a class="card" href="/trophies">
    <h2><%= trophyCount %></h2>
    <p>Trophy items</p>
  </a>
  <a class="card" href="/completions">
    <h2><%= completionCount %></h2>
    <p>Digital completions</p>
  </a>
</section>

<% if (currentlyReading && currentlyReading.length > 0) { %>
  <h2>📖 Currently reading <a href="/readings" class="hint" style="font-size:.7em;">all →</a></h2>
  <ul class="reading-list reading-list-compact">
    <% currentlyReading.forEach(function(r) { %>
      <li>
        <strong><%= r.user.displayName %></strong> —
        <a href="/library/copy/<%= r.copy.id %>"><em><%= r.copy.book.title %></em></a>
        <span class="hint">started <%= new Date(r.startedAt).toISOString().slice(0,10) %></span>
      </li>
    <% }) %>
  </ul>
<% } %>

<% if (recent && recent.length > 0) { %>
  <h2>Recently added</h2>
  <ul class="poster-grid poster-grid-compact">
    <% recent.forEach(function(c) {
      const cover = c.coverPath ? '/uploads/' + c.coverPath : c.book.thumbnailUrl;
    %>
      <li class="poster">
        <a href="/library/copy/<%= c.id %>" class="poster-link" aria-label="<%= c.book.title %>">
          <% if (cover) { %>
            <img src="<%= cover %>" alt="" loading="lazy" />
          <% } else { %>
            <div class="poster-fallback"><span><%= c.book.title %></span></div>
          <% } %>
          <div class="poster-meta">
            <strong class="poster-title"><%= c.book.title %></strong>
            <span class="poster-author"><%= c.book.authors.join(', ') %></span>
          </div>
        </a>
      </li>
    <% }) %>
  </ul>
<% } %>

<% if (activity && activity.length > 0) { %>
  <h2>Recent activity</h2>
  <ul class="activity-feed">
    <% activity.forEach(function(a) { %>
      <li>
        <span class="hint"><%= a.when.toISOString().replace('T',' ').slice(0,16) %></span>
        <% if (a.who) { %><strong><%= a.who %></strong> <% } %><%= a.verb %>
        <% if (a.bookTitle && a.href) { %>
          <a href="<%= a.href %>"><%= a.bookTitle %></a>
        <% } else if (a.bookTitle) { %>
          <em><%= a.bookTitle %></em>
        <% } else { %>
          <em>(deleted)</em>
        <% } %>
      </li>
    <% }) %>
  </ul>
<% } %>

<%- include('_footer') %>
