<% const pageTitle = 'Trophies' %>
<%- include('_header') %>

<h1>🏆 Trophy List</h1>

<% if (trophies.length === 0) { %>
  <p>No Trophy items yet. Add one from <a href="/completions/new">a new completion</a>.</p>
<% } else { %>
  <table class="data">
    <thead>
      <tr><th>Title</th><th>Authors</th><th>Requested by</th><th>Priority</th><th>Format</th><th></th></tr>
    </thead>
    <tbody>
      <% trophies.forEach(function(t) { %>
        <tr>
          <td data-label="Title"><a href="/books/<%= t.bookId %>"><%= t.book.title %></a></td>
          <td data-label="Authors"><%= t.book.authors.join(', ') %></td>
          <td data-label="Requested by"><%= t.requestedBy.displayName %></td>
          <td data-label="Priority"><%= t.priority %></td>
          <td data-label="Format"><%= t.desiredFormat || '—' %></td>
          <td data-label="">
            <form method="post" action="/trophies/<%= t.id %>/delete" onsubmit="return confirm('Remove this trophy?')">
              <button type="submit" class="danger">Remove</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('_footer') %>
