<% const pageTitle = name %>
<%- include('_header') %>

<p><a href="/series">← all series</a></p>

<h1>📚 <%= name %></h1>

<ol class="series-list">
  <% books.forEach(function(b) { %>
    <li>
      <% if (b.seriesPosition !== null) { %><strong>#<%= b.seriesPosition %></strong> · <% } %>
      <a href="/books/<%= b.id %>"><%= b.title %></a>
      <span class="hint">— <%= b.authors.join(', ') %></span>
      <% if (b.physicalCopies.length > 0) { %><span class="pill pill-library">📚 owned</span><% } %>
      <% if (b.trophies.length > 0) { %><span class="pill pill-trophy">🏆 trophy</span><% } %>
    </li>
  <% }) %>
</ol>

<%- include('_footer') %>
