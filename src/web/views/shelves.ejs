<% const pageTitle = 'Shelves' %>
<%- include('_header') %>

<%- include('_page_hero', {
  icon: '📚',
  title: 'Shelves',
  blurb: 'Named collections of physical copies — bookcases, themed lists, and series you own books from.',
  stats: rails.length > 0 ? [
    { value: shelfCount, label: 'shelves' },
    seriesCount > 0 ? { value: seriesCount, label: 'series' } : null,
    { value: totalOrganised, label: 'cop' + (totalOrganised === 1 ? 'y' : 'ies') + ' organised' }
  ] : null
}) %>

<% if (rails.length === 0) { %>
  <p>No shelves or series yet. Add a shelf to a copy or set <code>seriesName</code> on a book to see them appear here.</p>
<% } else { %>
  <div class="shelf-rails">
    <% rails.forEach(function(rail) {
      if (!rail.tiles || rail.tiles.length === 0) return;
      const isSeries = rail.kind === 'series';
      const detailHref = isSeries
        ? '/series?name=' + encodeURIComponent(rail.name)
        : '/shelves/' + rail.slug;
    %>
      <section class="shelf-rail<%= isSeries ? ' is-series' : '' %>">
        <header class="shelf-rail-head">
          <h2>
            <a href="<%= detailHref %>"><%= rail.name %><% if (rail.isOrdered) { %> <span class="ord">▦</span><% } %></a>
            <% if (isSeries) { %><span class="rail-kind">series</span><% } %>
          </h2>
          <span class="shelf-rail-count"><%= rail.total %> book<%= rail.total === 1 ? '' : 's' %></span>
          <a class="shelf-rail-all" href="<%= detailHref %>">view all →</a>
        </header>
        <div class="shelf-rail-wrap">
          <button type="button" class="shelf-rail-arrow left" aria-label="Scroll left" hidden>◀</button>
          <ul class="shelf-rail-track" role="list">
            <% rail.tiles.forEach(function(tile, idx) {
              const cover = tile.coverPath ? '/uploads/' + tile.coverPath : tile.thumbnailUrl;
              const positionLabel = (rail.isOrdered && tile.position !== null && tile.position !== undefined)
                ? '#' + (Number.isInteger(tile.position) ? tile.position : tile.position.toFixed(1))
                : null;
            %>
              <li class="shelf-rail-tile">
                <a href="/library/copy/<%= tile.copyId %>" class="shelf-rail-link" aria-label="<%= tile.title %>">
                  <div class="shelf-rail-cover<%= cover ? '' : ' no-cover' %>">
                    <% if (cover) { %>
                      <img src="<%= cover %>" alt="" loading="<%= idx < 6 ? 'eager' : 'lazy' %>" />
                    <% } else { %>
                      <span class="shelf-rail-fallback"><%= tile.title %></span>
                    <% } %>
                    <% if (positionLabel) { %><span class="shelf-rail-pos"><%= positionLabel %></span><% } %>
                  </div>
                  <div class="shelf-rail-meta">
                    <strong class="shelf-rail-title"><%= tile.title %></strong>
                    <% if (tile.primaryAuthor) { %>
                      <span class="shelf-rail-author"><%= tile.primaryAuthor %></span>
                    <% } %>
                  </div>
                </a>
              </li>
            <% }) %>
            <% if (rail.total > rail.tiles.length) { %>
              <li class="shelf-rail-tile shelf-rail-more">
                <a href="<%= detailHref %>" class="shelf-rail-link" aria-label="View all books on <%= rail.name %>">
                  <div class="shelf-rail-more-cover">
                    <span>+ <%= rail.total - rail.tiles.length %> more</span>
                  </div>
                  <div class="shelf-rail-meta">
                    <strong class="shelf-rail-title">View all</strong>
                  </div>
                </a>
              </li>
            <% } %>
          </ul>
          <button type="button" class="shelf-rail-arrow right" aria-label="Scroll right" hidden>▶</button>
        </div>
      </section>
    <% }) %>
  </div>
<% } %>

<script>
  // Show/hide rail arrows based on scroll position.
  (function() {
    document.querySelectorAll('.shelf-rail-wrap').forEach(function(wrap) {
      var track = wrap.querySelector('.shelf-rail-track');
      var left = wrap.querySelector('.shelf-rail-arrow.left');
      var right = wrap.querySelector('.shelf-rail-arrow.right');
      if (!track || !left || !right) return;
      function update() {
        var maxScroll = track.scrollWidth - track.clientWidth - 4;
        left.hidden = track.scrollLeft <= 4;
        right.hidden = track.scrollLeft >= maxScroll;
      }
      function step(dir) {
        var amount = Math.round(track.clientWidth * 0.8) * dir;
        track.scrollBy({ left: amount, behavior: 'smooth' });
      }
      left.addEventListener('click', function(e) { e.preventDefault(); step(-1); });
      right.addEventListener('click', function(e) { e.preventDefault(); step(1); });
      track.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
      update();
    });
  })();
</script>

<%- include('_footer') %>
