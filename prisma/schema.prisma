// Paper Hoard data model — see docs/v1-scope.md
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Library {
  id              String         @id @default(cuid())
  discordGuildId  String         @unique
  name            String
  publicSlug      String?        @unique
  notifyChannelId String?
  createdAt       DateTime       @default(now())

  memberships     Membership[]
  physicalCopies  PhysicalCopy[]
  trophies        Trophy[]
  completions     Completion[]
  shelves         Shelf[]
  readings        Reading[]
}

model User {
  id              String         @id @default(cuid())
  discordUserId   String         @unique
  displayName     String
  createdAt       DateTime       @default(now())

  memberships       Membership[]
  addedCopies       PhysicalCopy[] @relation("AddedBy")
  completions       Completion[]
  requestedTrophies Trophy[]       @relation("RequestedBy")
  readings          Reading[]
}

model Membership {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  library     Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  libraryId   String
  createdAt   DateTime @default(now())

  @@unique([userId, libraryId])
}

model Book {
  id             String         @id @default(cuid())
  isbn13         String?        @unique
  isbn10         String?
  title          String
  authors        String[]
  primaryAuthor  String?
  publisher      String?
  publishedAt    String?
  thumbnailUrl   String?
  source         String?        // "google_books" | "open_library" | "manual"
  olWorkId       String?
  olRatingAvg    Float?
  olRatingCount  Int?
  olFetchedAt    DateTime?
  createdAt      DateTime       @default(now())

  physicalCopies PhysicalCopy[]
  completions    Completion[]
  trophies       Trophy[]

  @@index([primaryAuthor])
}

model PhysicalCopy {
  id            String   @id @default(cuid())
  book          Book     @relation(fields: [bookId], references: [id])
  bookId        String
  library       Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  libraryId     String
  addedBy       User     @relation("AddedBy", fields: [addedByUserId], references: [id])
  addedByUserId String
  condition     String?
  edition       String?
  notes         String?
  coverPath     String?
  addedAt       DateTime @default(now())
  deletedAt     DateTime?

  shelves       ShelfCopy[]
  readings      Reading[]

  @@index([deletedAt])
}

model Reading {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  library    Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  libraryId  String
  copy       PhysicalCopy @relation(fields: [copyId], references: [id], onDelete: Cascade)
  copyId     String
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  notes      String?

  @@index([userId, finishedAt])
  @@index([libraryId, finishedAt])
}

model Shelf {
  id        String   @id @default(cuid())
  library   Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  libraryId String
  name      String
  slug      String
  isOrdered Boolean  @default(false)
  createdAt DateTime @default(now())

  copies    ShelfCopy[]

  @@unique([libraryId, slug])
}

model ShelfCopy {
  shelf    Shelf        @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  shelfId  String
  copy     PhysicalCopy @relation(fields: [copyId], references: [id], onDelete: Cascade)
  copyId   String
  position Float?

  @@id([shelfId, copyId])
  @@index([copyId])
}

model Completion {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  library       Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  libraryId     String
  book          Book     @relation(fields: [bookId], references: [id])
  bookId        String
  mediaType     String   // "ebook" | "audiobook"
  source        String?
  completedOn   DateTime?
  rating        Int?
  notes         String?
  createdAt     DateTime @default(now())
}

model Trophy {
  id                String   @id @default(cuid())
  library           Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  libraryId         String
  book              Book     @relation(fields: [bookId], references: [id])
  bookId            String
  requestedBy       User     @relation("RequestedBy", fields: [requestedByUserId], references: [id])
  requestedByUserId String
  desiredFormat     String?
  priority          Int      @default(3)
  reason            String?
  createdAt         DateTime @default(now())

  @@unique([libraryId, bookId])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String   // "create" | "update" | "delete"
  entity      String   // "physicalCopy" | "trophy" | "completion" | "book"
  entityId    String
  details     Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([entity, entityId])
}

model OutboundNotification {
  id          String   @id @default(cuid())
  kind        String   // "trophy-acquired" | future kinds
  payload     Json
  status      String   @default("pending") // pending | sent | failed
  attempts    Int      @default(0)
  lastError   String?
  createdAt   DateTime @default(now())
  processedAt DateTime?

  @@index([status, createdAt])
}
