# --- Database ---
# Used by Prisma and the app. In docker compose, host = "postgres".
DATABASE_URL=postgresql://paperhoard:paperhoard@localhost:5432/paperhoard?schema=public

# Postgres container (only used by docker compose)
POSTGRES_USER=paperhoard
POSTGRES_PASSWORD=paperhoard
POSTGRES_DB=paperhoard

# --- Smaug (Discord bot) ---
# From https://discord.com/developers/applications
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Required for Discord OAuth login on the web UI. From the OAuth2 page in the
# Developer Portal — different from DISCORD_TOKEN!
DISCORD_CLIENT_SECRET=
# Comma-separated guild IDs. Used by Smaug to register slash commands AND by
# the web UI as the allow-list for OAuth login (users not in any of these
# guilds are rejected).
DISCORD_GUILD_IDS=

# --- Web UI ---
WEB_PORT=3000
# Public base URL the web UI is reached at. Used to build the Discord OAuth
# redirect URI. Must exactly match an entry in your Discord app's "Redirects"
# list. Example: https://obrienserver.local:8443
WEB_BASE_URL=
# Used to sign session/state cookies (any random string).
COOKIE_SECRET=change-me-to-a-long-random-string

# --- Metadata providers ---
# Optional. Open Library fallback works without a key.
GOOGLE_BOOKS_API_KEY=
# Optional 3rd-tier cover rescue. Free key from
# https://www.librarything.com/services/keys.php — used with the
# thingISBN endpoint to find sister editions of a work; we then try
# Google Books / Open Library on those when the user's specific
# edition has no cover anywhere. Leave blank to skip this fallback.
LIBRARYTHING_DEVKEY=

# --- Uploads ---
# Directory for cover-photo uploads. Bind-mount this to a TrueNAS dataset
# in production so snapshots cover photos.
UPLOADS_DIR=./data/uploads

# --- Logging ---
LOG_LEVEL=info
